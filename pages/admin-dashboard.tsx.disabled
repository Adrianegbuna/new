              <div 
                className="bg-gradient-to-br from-cyan-500 to-teal-600 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => setActiveTab('installments')}
              >
                <div>
                  <div className="text-3xl mb-2">📦💳</div>
                  <h3 className="text-base font-bold mb-1">Installments</h3>
                </div>
                <p className="text-xs opacity-90">Manage Pay Small Small orders</p>
              </div>

              {/* Referral Management */}
              <div 
                className="bg-gradient-to-br from-indigo-500 to-blue-600 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => setActiveTab('analytics')}
              >
                <div>
                  <div className="text-3xl mb-2">💰</div>
                  <h3 className="text-base font-bold mb-1">Referral Mgmt</h3>
                </div>
                <p className="text-xs opacity-90">Track commission payments</p>
              </div>

              {/* Payout Requests */}
              <div 
                className="bg-gradient-to-br from-green-500 to-emerald-600 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => setActiveTab('inventory')}
              >
                <div>
                  <div className="text-3xl mb-2">💵</div>
                  <h3 className="text-base font-bold mb-1">Payout Requests</h3>
                </div>
                <p className="text-xs opacity-90">Approve & process payouts</p>
              </div>

              {/* Admin Settings */}
              <div 
                className="bg-gradient-to-br from-gray-600 to-gray-800 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => router.push('/admin-profile')}
              >
                <div>
                  <div className="text-3xl mb-2">⚙️</div>
                  <h3 className="text-base font-bold mb-1">Admin Settings</h3>
                </div>
                <p className="text-xs opacity-90">Manage account</p>
              </div>

              {/* Order Management */}
              <div 
                className="bg-gradient-to-br from-indigo-600 to-indigo-800 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => router.push('/admin/orders-management')}
              >
                <div>
                  <div className="text-3xl mb-2">📦📋</div>
                  <h3 className="text-base font-bold mb-1">Order Mgmt</h3>
                </div>
                <p className="text-xs opacity-90">Track all orders & customers</p>
              </div>

              {/* Categories Management */}
              <div 
                className="bg-gradient-to-br from-amber-500 to-yellow-600 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => setActiveTab('categories')}
              >
                <div>
                  <div className="text-3xl mb-2">🏷️</div>
                  <h3 className="text-base font-bold mb-1">Categories</h3>
                </div>
                <p className="text-xs opacity-90">Manage categories & subcategories</p>
              </div>

              {/* Post Product to Vendor */}
              <div 
                className="bg-gradient-to-br from-teal-600 to-cyan-600 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => setActiveTab('post-product')}
              >
                <div>
                  <div className="text-3xl mb-2">📦✨</div>
                  <h3 className="text-base font-bold mb-1">Post to Store</h3>
                </div>
                <p className="text-xs opacity-90">Help vendors post products</p>
              </div>

              {/* Flash Deals */}
              <div 
                className="bg-gradient-to-br from-red-500 to-orange-600 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => setActiveTab('flash-deals')}
              >
                <div>
                  <div className="text-3xl mb-2">🔥⚡</div>
                  <h3 className="text-base font-bold mb-1">Flash Deals</h3>
                </div>
                <p className="text-xs opacity-90">Post solar package deals</p>
              </div>

              {/* Flash Deals Orders */}
              <div 
                className="bg-gradient-to-br from-orange-500 to-red-500 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => setActiveTab('flash-deals')}
              >
                <div>
                  <div className="text-3xl mb-2">📦🔥</div>
                  <h3 className="text-base font-bold mb-1">Flash Deal Orders</h3>
                </div>
                <p className="text-xs opacity-90">Manage flash deals orders</p>
              </div>

              {/* Swap & Resell Orders */}
              <div 
                className="bg-gradient-to-br from-purple-500 to-pink-600 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => setActiveTab('swap-resell')}
              >
                <div>
                  <div className="text-3xl mb-2">📦🔄</div>
                  <h3 className="text-base font-bold mb-1">Swap/Resell Orders</h3>
                </div>
                <p className="text-xs opacity-90">Manage swap/resell orders</p>
              </div>

              {/* Swap & Resell Management */}
              <div 
                className="bg-gradient-to-br from-indigo-500 to-purple-600 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => router.push('/admin-swap-resell')}
              >
                <div>
                  <div className="text-3xl mb-2">🔄💰</div>
                  <h3 className="text-base font-bold mb-1">Swap & Resell</h3>
                </div>
                <p className="text-xs opacity-90">Approve resale & trade-in</p>
              </div>
            </div>
          </div>

          <div className="mb-8 border-b-2 border-gray-200 pb-4">
            <div className="flex flex-wrap gap-2 md:gap-4">
              {['overview', 'users', 'orders', 'products', 'stores', 'quotations', 'packages', 'jobs', 'service-requests', 'analytics', 'inventory', 'promotions', 'reviews', 'payments', 'cheques', 'categories', 'post-product', 'flash-deals', 'swap-resell', 'installments'].map(tab => (
                <button
                  key={tab}
                  onClick={() => setActiveTab(tab as any)}
                  className={`px-3 md:px-4 py-2 font-semibold transition-all border-b-2 capitalize text-sm md:text-base whitespace-nowrap ${
                    activeTab === tab
                      ? 'border-teal-500 text-teal-600'
                      : 'border-transparent text-gray-600 hover:text-gray-900'
                  }`}
                >
                  {tab.replace('-', ' ')}
                </button>
              ))}
            </div>
          </div>

          <div className="bg-white rounded-xl shadow-md p-6">
            {activeTab === 'overview' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">Platform Overview</h3>
                <p className="text-gray-600">Dashboard overview information</p>
              </div>
            )}

            {activeTab === 'users' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">User Management</h3>
                {users.length === 0 ? (
                  <p className="text-gray-600">No users found</p>
                ) : (
                  <div className="overflow-x-auto">
                    <table className="w-full text-left text-sm">
                      <thead className="bg-gray-100 border-b">
                        <tr>
                          <th className="px-4 py-2 font-semibold">Name</th>
                          <th className="px-4 py-2 font-semibold">Email</th>
                          <th className="px-4 py-2 font-semibold">Role</th>
                          <th className="px-4 py-2 font-semibold">Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        {users.map(u => (
                          <tr key={u.id} className="border-b hover:bg-gray-50">
                            <td className="px-4 py-2">{u.firstName} {u.lastName}</td>
                            <td className="px-4 py-2">{u.email}</td>
                            <td className="px-4 py-2"><span className="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs font-semibold">{u.role}</span></td>
                            <td className="px-4 py-2"><button onClick={() => deleteUser(u.id)} className="text-red-600 hover:text-red-800 text-sm font-bold">Delete</button></td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            )}

            {activeTab === 'orders' && (
              <div>
                <div className="flex justify-between items-center mb-8">
                  <h2 className="text-2xl font-bold text-gray-900">Order Management</h2>
                  <Link href="/admin/orders-management">
                    <button className="px-6 py-3 bg-teal-600 text-white font-semibold rounded-lg hover:bg-teal-700 active:bg-teal-800 transition shadow-md hover:shadow-lg">
                      View Full Order Management
                    </button>
                  </Link>
                </div>
                {orders.length === 0 ? (
                  <p className="text-gray-600">No orders found</p>
                ) : (
                  <div className="space-y-4">
                    {orders.slice(0, 10).map((order) => {
                      const currentDeliveryStatus = orderStatusChanges[order.id]?.deliveryStatus || order.orderStatus;
                      const currentPaymentStatus = orderStatusChanges[order.id]?.paymentStatus || order.paymentStatus;
                      const isRefunded = refundedOrders.has(order.id);

                      return (
                        <div key={order.id} className="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow p-6 border border-gray-100">
                          
                          {/* Header: Order ID, Date, Status Dropdowns */}
                          <div className="flex justify-between items-start mb-6 pb-4 border-b border-gray-200">
                            <div>
                              <p className="text-xs font-bold text-gray-600 uppercase tracking-wide">Order ID</p>
                              <p className="font-mono font-bold text-gray-900 mt-1">{order.orderNumber || order.id.slice(0, 8)}</p>
                            </div>
                            <div className="text-center">
                              <p className="text-xs font-bold text-gray-600 uppercase tracking-wide">Date</p>
                              <p className="font-bold text-gray-900 mt-1">{new Date(order.createdAt).toLocaleDateString()}</p>
                            </div>
                            <div className="text-right">
                              <p className="text-xs font-bold text-gray-600 uppercase tracking-wide mb-2">Status</p>
                              <div className="flex gap-2 justify-end flex-wrap">
                                {/* Delivery Status Dropdown */}
                                <select
                                  value={currentDeliveryStatus}
                                  onChange={(e) => setOrderStatusChanges({
                                    ...orderStatusChanges,
                                    [order.id]: { ...orderStatusChanges[order.id], deliveryStatus: e.target.value }
                                  })}
                                  className={`px-3 py-1 rounded-full text-xs font-bold border-0 cursor-pointer ${
                                    currentDeliveryStatus === 'delivered' ? 'bg-green-100 text-green-800' :
                                    currentDeliveryStatus === 'shipped' ? 'bg-blue-100 text-blue-800' :
                                    currentDeliveryStatus === 'processing' ? 'bg-yellow-100 text-yellow-800' :
                                    'bg-orange-100 text-orange-800'
                                  }`}
                                >
                                  <option value="pending">Pending</option>
                                  <option value="processing">Processing</option>
                                  <option value="shipped">Shipped</option>
                                  <option value="delivered">Delivered</option>
                                </select>

                                {/* Payment Status Dropdown */}
                                <select
                                  value={currentPaymentStatus}
                                  onChange={(e) => setOrderStatusChanges({
                                    ...orderStatusChanges,
                                    [order.id]: { ...orderStatusChanges[order.id], paymentStatus: e.target.value }
                                  })}
                                  disabled={isRefunded}
                                  className={`px-3 py-1 rounded-full text-xs font-bold border-0 cursor-pointer ${
                                    isRefunded ? 'bg-red-100 text-red-800 opacity-75 cursor-not-allowed' :
                                    currentPaymentStatus === 'paid' || currentPaymentStatus === 'completed' ? 'bg-green-100 text-green-800' :
                                    currentPaymentStatus === 'pending' ? 'bg-orange-100 text-orange-800' :
                                    currentPaymentStatus === 'failed' ? 'bg-red-100 text-red-800' :
                                    'bg-red-100 text-red-800'
                                  }`}
                                >
                                  <option value="pending">Pending</option>
                                  <option value="paid">Paid</option>
                                  <option value="failed">Failed</option>
                                  {isRefunded && <option value="refunded">Refunded</option>}
                                </select>
                              </div>
                            </div>
                          </div>

                          {/* Items Ordered */}
                          <div className="mb-6">
                            <p className="font-bold text-gray-900 mb-4">Items Ordered</p>
                            <div className="space-y-4">
                              {order.items && order.items.length > 0 ? (
                                order.items.map((item, idx) => {
                                  // ✅ FIX: Map to actual API response structure
                                  // API returns: item.product.image, item.product.name
                                  const product = item.product || {} as any;
                                  const productImage = product.image || item.image || '';
                                  const productName = product.name || item.name || 'Unknown Product';
                                  
                                  // Construct proper image URL from backend
                                  const baseUrl = process.env.NEXT_PUBLIC_API_URL || 'https://renewablezmart-backend.onrender.com/api';
                                  const backendBaseUrl = baseUrl.replace('/api', '');
                                  
                                  let imageUrl = productImage;
                                  
                                  // If image is a relative path, prepend backend base URL
                                  if (imageUrl && !imageUrl.startsWith('http') && !imageUrl.startsWith('/')) {
                                    imageUrl = `${backendBaseUrl}/${imageUrl}`;
                                  } else if (imageUrl && imageUrl.startsWith('/uploads')) {
                                    imageUrl = `${backendBaseUrl}${imageUrl}`;
                                  }
                                  
                                  // Fallback to placeholder
                                  const finalImageUrl = imageUrl || '/placeholder.png';
                                  
                                  return (
                                    <div key={idx} className="flex gap-4 items-start">
                                      {/* Product Thumbnail */}
                                      <div className="w-16 h-16 rounded-md bg-gray-100 flex-shrink-0 overflow-hidden flex items-center justify-center">
                                        {productImage ? (
                                          <img 
                                            src={finalImageUrl}
                                            alt={productName}
                                            className="w-full h-full object-cover"
                                            onError={(e) => {
                                              console.warn(`Image failed to load: ${finalImageUrl}`);
                                              (e.target as HTMLImageElement).src = '/placeholder.png';
                                            }}
                                          />
                                        ) : (
                                          <span className="text-xl">📦</span>
                                        )}
                                      </div>
                                      {/* Product Details */}
                                      <div className="flex-1 flex justify-between items-start">
                                        <div className="flex-1">
                                          <p className="font-bold text-gray-900">{productName}</p>
                                          <p className="text-sm text-gray-600 mt-1">Qty: {item.quantity} | Price: ₦{(item.price || 0).toLocaleString()}</p>
                                        </div>
                                        {/* Subtotal */}
                                        <div className="text-right flex-shrink-0 ml-4">
                                          <p className="text-xs text-gray-600 font-bold mb-1">Subtotal</p>
                                          <p className="font-bold text-green-600">₦{((item.price || 0) * (item.quantity || 1)).toLocaleString()}</p>
                                        </div>
                                      </div>
                                    </div>
                                  );
                                })
                              ) : (
                                <p className="text-gray-500 italic">No items in this order</p>
                              )}
                            </div>
                          </div>

                          {/* Store, Customer Info & Total */}
                          <div className="flex justify-between items-start pt-4 border-t border-gray-200 mb-4">
                            <div>
                              <p className="text-xs font-bold text-gray-600 uppercase tracking-wide mb-2">Customer</p>
                              <p className="font-bold text-gray-900">{order.customer?.fullName || order.customerName || 'N/A'}</p>
                              <p className="text-sm text-gray-600">{order.customer?.email || 'N/A'}</p>
                              {order.store && (
                                <>
                                  <p className="text-xs font-bold text-gray-600 uppercase tracking-wide mt-3 mb-1">Vendor Store</p>
                                  <p className="text-sm font-semibold text-gray-900">{order.store.name}</p>
                                </>
                              )}
                            </div>
                            <div className="text-right flex-shrink-0">
                              <p className="text-xs font-bold text-gray-600 uppercase tracking-wide mb-2">Total</p>
                              <p className="text-3xl font-bold text-green-600">{formatPrice(order.totalPrice || order.total || 0)}</p>
                            </div>
                          </div>

                          {/* Update Order Status Button */}
                          <div className="pt-6 mt-6 border-t-2 border-emerald-400">
                            <button
                              onClick={() => {
                                setUpdatingOrderId(order.id);
                                setNewOrderStatus(order.orderStatus || 'pending');
                                setUpdateStatusError('');
                              }}
                              className="w-full px-6 py-4 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white font-bold rounded-lg transition text-base shadow-lg hover:shadow-xl"
                            >
                              📝 Update Order Status
                            </button>
                          </div>

                          {/* Refund Button */}
                          {currentPaymentStatus === 'paid' && (
                            <div className="pt-4 border-t border-gray-200">
                              {isRefunded ? (
                                <button disabled className="w-full px-4 py-2 bg-red-100 text-red-800 font-bold rounded-lg opacity-75 cursor-not-allowed">
                                  ✓ Refunded
                                </button>
                              ) : (
                                <button
                                  onClick={() => setRefundConfirmOrderId(order.id)}
                                  className="w-full px-4 py-2 bg-red-600 hover:bg-red-700 active:bg-red-800 text-white font-bold rounded-lg transition"
                                >
                                  💰 Process Refund
                                </button>
                              )}
                            </div>
                          )}
                        </div>
                      );
                    })}

                    {orders.length > 10 && (
                      <div className="text-center pt-4">
                        <p className="text-sm text-gray-600">Showing 10 of {orders.length} orders. <Link href="/admin/orders-management"><span className="text-teal-600 font-bold cursor-pointer hover:underline">View all</span></Link></p>
                      </div>
                    )}
                  </div>
                )}

                {/* Update Order Status Modal */}
                {updatingOrderId && (
                  <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
                    <div className="bg-white dark:bg-gray-800 rounded-lg shadow-2xl p-8 w-full max-w-md relative z-50 max-h-screen overflow-y-auto">
                      {/* Close Button */}
                      <button
                        onClick={() => {
                          setUpdatingOrderId(null);
                          setNewOrderStatus('');
                          setUpdateStatusError('');
                        }}
                        className="absolute top-4 right-4 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 text-2xl font-bold"
                      >
                        ✕
                      </button>

                      <h3 className="text-2xl font-bold text-gray-900 dark:text-white mb-6 pr-8">📦 Update Order Status</h3>
                      
                      {updateStatusError && (
                        <div className="mb-4 p-3 bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 rounded-lg text-sm font-bold">
                          {updateStatusError}
                        </div>
                      )}

                      <div className="space-y-6 mb-6">
                        {/* Status Selection */}
                        <div>
                          <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-3">
                            Select New Status
                          </label>
                          <select
                            value={newOrderStatus}
                            onChange={(e) => setNewOrderStatus(e.target.value)}
                            className="w-full px-4 py-3 border-2 border-emerald-400 rounded-lg dark:bg-gray-700 dark:text-white dark:border-emerald-500 font-semibold focus:outline-none focus:ring-2 focus:ring-emerald-500"
                          >
                            <option value="pending">📋 Pending</option>
                            <option value="processing">⚙️ Processing</option>
                            <option value="shipped">📦 Shipped</option>
                            <option value="delivered">✅ Delivered</option>
                            <option value="cancelled">❌ Cancelled</option>
                          </select>
                        </div>
                      </div>

                      {/* Modal Action Buttons */}
                      <div className="flex gap-3">
                        <button
                          onClick={() => {
                            setUpdatingOrderId(null);
                            setNewOrderStatus('');
                            setUpdateStatusError('');
                          }}
                          className="flex-1 px-4 py-3 border-2 border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-bold rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition"
                        >
                          Cancel
                        </button>
                        <button
                          onClick={async () => {
                            if (!newOrderStatus) {
                              setUpdateStatusError('Please select a status');
                              return;
                            }

                            setUpdateStatusLoading(true);
                            setUpdateStatusError('');

                            try {
                              const response = await apiClient.patch(`/orders/${updatingOrderId}/status`, {
                                status: newOrderStatus
                              });

                              if (response.status === 200) {
                                // Update orders list with new status
                                setOrders(orders.map(o => 
                                  o.id === updatingOrderId 
                                    ? { ...o, orderStatus: newOrderStatus }
                                    : o
                                ));
                                
                                // Close modal
                                setUpdatingOrderId(null);
                                setNewOrderStatus('');
                                setUpdateStatusError('');
                                
                                // Show success alert
                                alert('✅ Order status updated successfully!');
                              }
                            } catch (error: any) {
                              console.error('Error updating order status:', error);
                              setUpdateStatusError(
                                error.response?.data?.message || 
                                'Failed to update order status. Please try again.'
                              );
                            } finally {
                              setUpdateStatusLoading(false);
                            }
                          }}
                          disabled={updateStatusLoading}
                          className="flex-1 px-4 py-3 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 disabled:opacity-50 disabled:cursor-not-allowed text-white font-bold rounded-lg transition"
                        >
                          {updateStatusLoading ? '⏳ Saving...' : '💾 Save Status'}
                        </button>
                      </div>
                    </div>
                  </div>
                )}

                {/* Refund Confirmation Modal */}
                {refundConfirmOrderId && (
                  <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
                    <div className="bg-white rounded-lg shadow-2xl p-6 max-w-sm w-full mx-4">
                      <h3 className="text-xl font-bold text-gray-900 mb-4">💰 Confirm Refund</h3>
                      <p className="text-gray-600 mb-6">
                        Are you sure you want to process a refund for order <span className="font-bold">{orders.find(o => o.id === refundConfirmOrderId)?.orderNumber || refundConfirmOrderId.slice(0, 8)}</span>? This action cannot be undone.
                      </p>
                      <div className="flex gap-3">
                        <button
                          onClick={() => setRefundConfirmOrderId(null)}
                          className="flex-1 px-4 py-2 border border-gray-300 text-gray-700 font-bold rounded-lg hover:bg-gray-100 transition"
                        >
                          Cancel
                        </button>
                        <button
                          onClick={() => {
                            setRefundedOrders(new Set([...refundedOrders, refundConfirmOrderId]));
                            setOrderStatusChanges({
                              ...orderStatusChanges,
                              [refundConfirmOrderId]: {
                                ...orderStatusChanges[refundConfirmOrderId],
                                paymentStatus: 'refunded'
                              }
                            });
                            setRefundConfirmOrderId(null);
                          }}
                          className="flex-1 px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-bold rounded-lg transition"
                        >
                          Confirm Refund
                        </button>
                      </div>
                    </div>
                  </div>
                )}
              </div>
            )}

            {activeTab === 'products' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">Product Management</h3>
                {products.length === 0 ? (
                  <p className="text-gray-600">No products found</p>
                ) : (
                  <div className="overflow-x-auto">
                    <table className="w-full text-left text-sm">
                      <thead className="bg-gray-100 border-b">
                        <tr>
                          <th className="px-4 py-2 font-semibold">Name</th>
                          <th className="px-4 py-2 font-semibold">Price</th>
                          <th className="px-4 py-2 font-semibold">Stock</th>
                        </tr>
                      </thead>
                      <tbody>
                        {products.map(p => (
                          <tr key={p.id} className="border-b hover:bg-gray-50">
                            <td className="px-4 py-2 font-semibold">{p.name}</td>
                            <td className="px-4 py-2">{formatPrice(p.price)}</td>
                            <td className="px-4 py-2">{p.stock} units</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            )}

            {activeTab === 'stores' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">Store Management</h3>
                {stores.length === 0 ? (
                  <p className="text-gray-600">No stores found</p>
                ) : (
                  <div className="grid md:grid-cols-2 gap-4">
                    {stores.map(store => (
                      <div key={store.id} className="border rounded-lg p-4 hover:shadow-md transition">
                        <h4 className="font-bold">{store.name}</h4>
                        <p className="text-sm text-gray-600">{store.city}, {store.country}</p>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )}

            {activeTab === 'quotations' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">Quotations</h3>
                <p className="text-gray-600">Manage installer service quotations and requests</p>
              </div>
            )}

            {activeTab === 'packages' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">Service Packages</h3>
                <p className="text-gray-600">Manage installer service package offerings</p>
              </div>
            )}

            {activeTab === 'jobs' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">Installation Jobs</h3>
                <p className="text-gray-600">Track and manage scheduled installation jobs</p>
              </div>
            )}

            {activeTab === 'service-requests' && (
              <div>
                <div className="flex justify-between items-center mb-6">
                  <div>
                    <h3 className="text-2xl font-bold text-gray-900 mb-2">📋 Service Requests</h3>
                    <p className="text-gray-600">Manage customer service requests and inquiries</p>
                  </div>
                </div>

                {serviceRequests.length === 0 ? (
                  <div className="bg-white rounded-lg shadow-md p-8 text-center">
                    <p className="text-gray-600">No service requests found</p>
                  </div>
                ) : (
                  <div className="space-y-4">
                    {serviceRequests.map((request: any) => (
                      <div key={request.id} className="bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-lg transition-shadow p-6 border border-gray-100 dark:border-gray-700">
                        
                        {/* Header: Customer Info & Status */}
                        <div className="flex justify-between items-start mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">
                          <div>
                            <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide">Customer Name</p>
                            <p className="font-bold text-gray-900 dark:text-white mt-1">{request.fullName || 'N/A'}</p>
                            <p className="text-sm text-gray-600 dark:text-gray-400 mt-1">{request.email || 'N/A'}</p>
                            <p className="text-sm text-gray-600 dark:text-gray-400 mt-1">📞 {request.phone || 'N/A'}</p>
                          </div>
                          <div className="text-right">
                            <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Request Date</p>
                            <p className="font-bold text-gray-900 dark:text-white">{new Date(request.createdAt).toLocaleDateString()}</p>
                            <p className="text-xs text-gray-600 dark:text-gray-400 mt-2">{new Date(request.createdAt).toLocaleTimeString()}</p>
                          </div>
                        </div>

                        {/* Service Details */}
                        <div className="mb-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                          <div>
                            <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Service Type</p>
                            <p className="font-semibold text-gray-900 dark:text-white bg-blue-50 dark:bg-blue-900 px-3 py-2 rounded-lg inline-block">
                              🔧 {request.serviceType || 'General Service'}
                            </p>
                          </div>
                          <div>
                            <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Status</p>
                            <div className="flex gap-2 flex-wrap">
                              <span className={`px-4 py-2 rounded-full text-xs font-bold ${
                                request.status === 'completed' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' :
                                request.status === 'assigned' ? 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200' :
                                request.status === 'in_progress' ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200' :
                                request.status === 'approved' ? 'bg-teal-100 text-teal-800 dark:bg-teal-900 dark:text-teal-200' :
                                request.status === 'rejected' ? 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200' :
                                'bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200'
                              }`}>
                                {request.status === 'pending' && '📋'}
                                {request.status === 'approved' && '✅'}
                                {request.status === 'assigned' && '👤'}
                                {request.status === 'in_progress' && '⚙️'}
                                {request.status === 'completed' && '✔️'}
                                {request.status === 'rejected' && '❌'}
                                {' '}{request.status || 'Pending'}
                              </span>
                            </div>
                          </div>
                        </div>

                        {/* Request Message */}
                        <div className="mb-6">
                          <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Request Details</p>
                          <div className="bg-gray-50 dark:bg-gray-700 rounded-lg p-4 border border-gray-200 dark:border-gray-600">
                            <p className="text-gray-900 dark:text-white text-sm">
                              {request.message || 'No additional details provided'}
                            </p>
                          </div>
                        </div>

                        {/* Customer Role */}
                        <div className="mb-6 bg-gray-50 dark:bg-gray-700 rounded-lg p-4">
                          <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div>
                              <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase mb-1">Customer Type</p>
                              <p className="text-sm text-gray-900 dark:text-white capitalize">{request.role || 'Customer'}</p>
                            </div>
                            <div>
                              <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase mb-1">Payment Status</p>
                              <p className="text-sm text-gray-900 dark:text-white">{request.isPaid ? '✅ Paid' : '⏳ Pending'}</p>
                            </div>
                            <div>
                              <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase mb-1">Assigned To</p>
                              <p className="text-sm text-gray-900 dark:text-white">{request.assignedUser?.firstName || 'Unassigned'}</p>
                            </div>
                          </div>
                        </div>

                        {/* Action Buttons */}
                        <div className="flex gap-3">
                          {request.status !== 'approved' && request.status !== 'completed' && (
                            <button 
                              onClick={async () => {
                                try {
                                  await apiClient.patch(`/service-requests/admin/${request.id}/status`, {
                                    status: 'approved',
                                    note: 'Request approved by admin'
                                  });
                                  
                                  // Refresh data
                                  await fetchDashboardData();
                                } catch (error: any) {
                                  alert(error.response?.data?.message || 'Failed to approve request');
                                }
                              }}
                              className="flex-1 px-6 py-3 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white font-bold rounded-lg transition text-sm shadow-md hover:shadow-lg"
                            >
                              ✅ Approve Request
                            </button>
                          )}
                          {request.status !== 'assigned' && request.status !== 'completed' && (
                            <button 
                              onClick={() => {
                                // For assigning, you'd typically open a modal to select installer
                                const installerUserId = prompt('Enter installer user ID to assign to:');
                                if (installerUserId) {
                                  (async () => {
                                    try {
                                      await apiClient.patch(`/service-requests/admin/${request.id}/assign`, {
                                        assignToUserId: installerUserId
                                      });
                                      
                                      // Refresh data
                                      await fetchDashboardData();
                                    } catch (error: any) {
                                      alert(error.response?.data?.message || 'Failed to assign request');
                                    }
                                  })();
                                }
                              }}
                              className="flex-1 px-6 py-3 bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-bold rounded-lg transition text-sm shadow-md hover:shadow-lg"
                            >
                              👤 Assign to Installer
                            </button>
                          )}
                          {request.status !== 'rejected' && request.status !== 'completed' && (
                            <button 
                              onClick={async () => {
                                try {
                                  await apiClient.patch(`/service-requests/admin/${request.id}/status`, {
                                    status: 'rejected',
                                    note: 'Request rejected by admin'
                                  });
                                  
                                  // Refresh data
                                  await fetchDashboardData();
                                } catch (error: any) {
                                  alert(error.response?.data?.message || 'Failed to reject request');
                                }
                              }}
                              className="flex-1 px-6 py-3 bg-red-600 hover:bg-red-700 active:bg-red-800 text-white font-bold rounded-lg transition text-sm shadow-md hover:shadow-lg"
                            >
                              ❌ Reject
                            </button>
                          )}
                          {request.status === 'completed' && (
                            <button disabled className="flex-1 px-6 py-3 bg-gray-400 text-white font-bold rounded-lg opacity-75 cursor-not-allowed text-sm">
                              ✔️ Completed
                            </button>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )}

            {activeTab === 'analytics' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">Analytics</h3>
                <p className="text-gray-600">Platform analytics, metrics, and performance data</p>
              </div>
            )}

            {activeTab === 'inventory' && (
              <div className="space-y-8">
                {/* Header */}
                <div>
                  <h3 className="text-2xl font-bold text-gray-900 mb-2">💰 Payout Requests</h3>
                  <p className="text-gray-600">Manage customer and installer referral payout requests</p>
                </div>

                {/* Payout Request Cards */}
                <div className="grid grid-cols-1 gap-6">
                  {payoutRequests && payoutRequests.length > 0 ? (
                    payoutRequests.map((payout: any) => (
                      <div key={payout.id} className="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden hover:shadow-lg transition">
                        {/* Header with Status */}
                        <div className="bg-gradient-to-r from-green-50 to-emerald-50 px-6 py-4 border-b border-gray-200">
                          <div className="flex justify-between items-start">
                            <div>
                              <h4 className="text-lg font-bold text-gray-900">{payout.user?.firstName} {payout.user?.lastName}</h4>
                              <p className="text-sm text-gray-600">{payout.user?.email}</p>
                            </div>
                            <div className="text-right">
                              <p className="text-2xl font-bold text-emerald-600">₦{(parseFloat(payout.amount) || 0).toLocaleString('en-NG', { minimumFractionDigits: 2 })}</p>
                              <div className={`inline-block px-3 py-1 rounded-full text-xs font-bold mt-2 ${
                                payout.status === 'pending' ? 'bg-amber-100 text-amber-700' :
                                payout.status === 'processing' ? 'bg-blue-100 text-blue-700' :
                                payout.status === 'completed' ? 'bg-green-100 text-green-700' :
                                'bg-red-100 text-red-700'
                              }`}>
                                {payout.status?.toUpperCase()}
                              </div>
                            </div>
                          </div>
                        </div>

                        {/* User & Bank Details */}
                        <div className="px-6 py-4 grid grid-cols-1 md:grid-cols-2 gap-6">
                          {/* User Information */}
                          <div className="space-y-3">
                            <h5 className="font-bold text-gray-900 mb-3">👤 User Details</h5>
                            <div className="text-sm space-y-2">
                              <p><span className="font-semibold text-gray-700">Name:</span> {payout.user?.firstName} {payout.user?.lastName}</p>
                              <p><span className="font-semibold text-gray-700">Email:</span> {payout.user?.email}</p>
                              <p><span className="font-semibold text-gray-700">Phone:</span> {payout.user?.phone || 'N/A'}</p>
                              <p><span className="font-semibold text-gray-700">Type:</span> <span className="inline-block px-2 py-1 bg-blue-100 text-blue-700 rounded text-xs font-bold">{payout.user?.role?.toUpperCase()}</span></p>
                              <p><span className="font-semibold text-gray-700">Country:</span> {payout.user?.country || 'N/A'}</p>
                            </div>
                          </div>

                          {/* Bank Details */}
                          <div className="space-y-3">
                            <h5 className="font-bold text-gray-900 mb-3">🏦 Bank Details</h5>
                            <div className="text-sm space-y-2 p-4 bg-gray-50 rounded-lg border border-gray-200">
                              <p><span className="font-semibold text-gray-700">Account Name:</span> {payout.user?.bankAccountName || 'N/A'}</p>
                              <p><span className="font-semibold text-gray-700">Account Number:</span> {payout.user?.bankAccountNumber || 'N/A'}</p>
                              <p><span className="font-semibold text-gray-700">Bank Name:</span> {payout.user?.bankName || 'N/A'}</p>
                              <p><span className="font-semibold text-gray-700">Bank Code:</span> {payout.user?.bankCode || 'N/A'}</p>
                              <p><span className="font-semibold text-gray-700">Country:</span> {payout.user?.bankCountry || 'N/A'}</p>
                            </div>
                          </div>
                        </div>

                        {/* Payout Details & Notes */}
                        <div className="px-6 py-4 border-t border-gray-200 space-y-4">
                          <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div className="p-4 bg-gradient-to-br from-emerald-50 to-teal-50 rounded-lg border border-emerald-200">
                              <p className="text-xs font-semibold text-emerald-600 mb-1">PAYOUT AMOUNT</p>
                              <p className="text-2xl font-bold text-emerald-700">₦{(parseFloat(payout.amount) || 0).toLocaleString('en-NG', { minimumFractionDigits: 2 })}</p>
                            </div>
                            <div className="p-4 bg-gradient-to-br from-blue-50 to-cyan-50 rounded-lg border border-blue-200">
                              <p className="text-xs font-semibold text-blue-600 mb-1">REQUESTED DATE</p>
                              <p className="text-lg font-bold text-blue-700">{new Date(payout.createdAt).toLocaleDateString()}</p>
                            </div>
                            <div className="p-4 bg-gradient-to-br from-purple-50 to-pink-50 rounded-lg border border-purple-200">
                              <p className="text-xs font-semibold text-purple-600 mb-1">PAYMENT METHOD</p>
                              <p className="text-lg font-bold text-purple-700">{payout.paymentMethod || 'Bank Transfer'}</p>
                            </div>
                          </div>

                          {payout.notes && (
                            <div className="p-4 bg-gray-50 rounded-lg border border-gray-200">
                              <p className="text-xs font-semibold text-gray-600 mb-2">📝 ADMIN NOTES</p>
                              <p className="text-gray-700">{payout.notes}</p>
                            </div>
                          )}
                        </div>

                        {/* Action Buttons */}
                        {payout.status === 'pending' && (
                          <div className="px-6 py-4 border-t border-gray-200 bg-gray-50 flex gap-3">
                            <button
                              onClick={async () => {
                                if (!payoutNotes.trim()) {
                                  alert('Please add admin notes');
                                  return;
                                }
                                setProcessingPayoutId(payout.id);
                                try {
                                  await apiClient.put(`/referrals/admin/payouts/${payout.id}`, {
                                    status: 'completed',
                                    notes: payoutNotes
                                  });
                                  setPayoutNotes('');
                                  await fetchDashboardData();
                                  alert('Payout approved and processed!');
                                } catch (error: any) {
                                  alert(error.response?.data?.message || 'Failed to process payout');
                                } finally {
                                  setProcessingPayoutId(null);
                                }
                              }}
                              disabled={processingPayoutId === payout.id}
                              className="flex-1 px-4 py-3 bg-green-600 hover:bg-green-700 active:bg-green-800 text-white font-bold rounded-lg transition disabled:opacity-50"
                            >
                              ✅ Approve & Process
                            </button>
                            <button
                              onClick={async () => {
                                if (!payoutNotes.trim()) {
                                  alert('Please add rejection reason in notes');
                                  return;
                                }
                                setProcessingPayoutId(payout.id);
                                try {
                                  await apiClient.put(`/referrals/admin/payouts/${payout.id}`, {
                                    status: 'failed',
                                    notes: payoutNotes
                                  });
                                  setPayoutNotes('');
                                  await fetchDashboardData();
                                  alert('Payout rejected');
                                } catch (error: any) {
                                  alert(error.response?.data?.message || 'Failed to reject payout');
                                } finally {
                                  setProcessingPayoutId(null);
                                }
                              }}
                              disabled={processingPayoutId === payout.id}
                              className="flex-1 px-4 py-3 bg-red-600 hover:bg-red-700 active:bg-red-800 text-white font-bold rounded-lg transition disabled:opacity-50"
                            >
                              ❌ Reject
                            </button>
                          </div>
                        )}

                        {/* Admin Notes Input (for pending requests) */}
                        {payout.status === 'pending' && processingPayoutId === payout.id && (
                          <div className="px-6 py-4 bg-yellow-50 border-t border-yellow-200">
                            <label className="block text-sm font-bold text-gray-700 mb-2">💬 Admin Notes</label>
                            <textarea
                              value={payoutNotes}
                              onChange={(e) => setPayoutNotes(e.target.value)}
                              placeholder="Add notes for approval or rejection reason..."
                              className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent h-24"
                            />
                          </div>
                        )}
                      </div>
                    ))
                  ) : (
                    <div className="bg-white rounded-xl shadow-md border border-gray-200 p-8 text-center">
                      <div className="text-6xl mb-4">💰</div>
                      <h4 className="text-xl font-bold text-gray-900 mb-2">No Pending Payout Requests</h4>
                      <p className="text-gray-600">All payout requests have been processed</p>
                    </div>
                  )}
                </div>
              </div>
            )}

            {activeTab === 'promotions' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">Promotions & Coupons</h3>
                <p className="text-gray-600">Create and manage promotional campaigns</p>
              </div>
            )}

            {activeTab === 'reviews' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">Reviews & Ratings</h3>
                <p className="text-gray-600">Manage customer reviews and ratings</p>
              </div>
            )}

            {activeTab === 'payments' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">Payments & Transactions</h3>
                <p className="text-gray-600">Track payments, transactions, and financial data</p>
              </div>
            )}

            {activeTab === 'cheques' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">Cheque Tracking</h3>
                <p className="text-gray-600">Monitor cheque submissions and verification status</p>
              </div>
            )}

            {activeTab === 'categories' && (
              <div className="space-y-8">
                {/* Header */}
                <div>
                  <h3 className="text-2xl font-bold text-gray-900 mb-2">Categories Management</h3>
                  <p className="text-gray-600">Manage product categories and subcategories from backend</p>
                </div>

                {/* Create Category Form */}
                <div className="bg-white rounded-xl shadow-md p-8 border border-gray-200">
                  <h4 className="text-xl font-bold text-gray-900 mb-6">
                    {editingCategory ? 'Edit Category' : 'Create New Category'}
                  </h4>
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Category Name *</label>
                      <input
                        type="text"
                        placeholder="e.g., Solar Panels"
                        value={categoryForm.name}
                        onChange={(e) => setCategoryForm({ ...categoryForm, name: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent"
                      />
                    </div>
                    <div className="md:col-span-2">
                      <label className="block text-sm font-bold text-gray-700 mb-2">Description</label>
                      <textarea
                        placeholder="Describe this category"
                        value={categoryForm.description}
                        onChange={(e) => setCategoryForm({ ...categoryForm, description: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent h-20"
                      />
                    </div>
                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Icon URL</label>
                      <input
                        type="text"
                        placeholder="https://..."
                        value={categoryForm.icon}
                        onChange={(e) => setCategoryForm({ ...categoryForm, icon: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent"
                      />
                    </div>
                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Image URL</label>
                      <input
                        type="text"
                        placeholder="https://..."
                        value={categoryForm.image}
                        onChange={(e) => setCategoryForm({ ...categoryForm, image: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent"
                      />
                    </div>
                  </div>
                  <div className="flex gap-4 mt-6">
                    {editingCategory ? (
                      <>
                        <button
                          onClick={() => handleUpdateCategory(editingCategory)}
                          className="px-6 py-2 bg-teal-600 text-white rounded-lg font-semibold hover:bg-teal-700 transition"
                        >
                          Update Category
                        </button>
                        <button
                          onClick={() => {
                            setEditingCategory(null)
                            setCategoryForm({ name: '', description: '', icon: '', image: '' })
                          }}
                          className="px-6 py-2 bg-gray-400 text-white rounded-lg font-semibold hover:bg-gray-500 transition"
                        >
                          Cancel
                        </button>
                      </>
                    ) : (
                      <button
                        onClick={handleCreateCategory}
                        className="px-6 py-2 bg-teal-600 text-white rounded-lg font-semibold hover:bg-teal-700 transition"
                      >
                        Create Category
                      </button>
                    )}
                  </div>
                </div>

                {/* Categories List */}
                <div className="space-y-4">
                  <h4 className="text-xl font-bold text-gray-900">Categories List ({categories.length})</h4>
                  {categories.length === 0 ? (
                    <div className="bg-gray-100 rounded-lg p-8 text-center text-gray-600">
                      No categories found. Create one using the form above.
                    </div>
                  ) : (
                    categories.map((category) => (
                      <div key={category.id} className="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
                        {/* Category Header */}
                        <div
                          onClick={() => setExpandedCategory(expandedCategory === category.id ? null : category.id)}
                          className="p-6 cursor-pointer hover:bg-gray-50 transition flex justify-between items-start"
                        >
                          <div className="flex-1">
                            <div className="flex items-center gap-3">
                              <h5 className="text-lg font-bold text-gray-900">{category.name}</h5>
                            </div>
                            {category.description && <p className="text-sm text-gray-600 mt-1">{category.description}</p>}
                            <p className="text-sm text-gray-500 mt-2">
                              Subcategories: {(category.subcategories || []).length}
                            </p>
                          </div>
                          <span className="text-2xl text-gray-400">{expandedCategory === category.id ? '▼' : '▶'}</span>
                        </div>

                        {/* Category Details Expanded */}
                        {expandedCategory === category.id && (
                          <div className="border-t border-gray-200 p-6 bg-gray-50">
                            <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                              {category.icon && (
                                <div>
                                  <p className="text-sm font-semibold text-gray-700">Icon:</p>
                                  <p className="text-sm text-gray-600 break-all">{category.icon}</p>
                                </div>
                              )}
                              {category.image && (
                                <div>
                                  <p className="text-sm font-semibold text-gray-700">Image:</p>
                                  <p className="text-sm text-gray-600 break-all">{category.image}</p>
                                </div>
                              )}
                            </div>

                            {/* Edit/Delete Actions */}
                            <div className="flex gap-3 mb-6">
                              <button
                                onClick={() => {
                                  setEditingCategory(category.id)
                                  setCategoryForm({
                                    name: category.name,
                                    description: category.description || '',
                                    icon: category.icon || '',
                                    image: category.image || ''
                                  })
                                }}
                                className="px-4 py-2 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition text-sm"
                              >
                                Edit
                              </button>
                              <button
                                onClick={() => handleDeleteCategory(category.id)}
                                className="px-4 py-2 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700 transition text-sm"
                              >
                                Delete
                              </button>
                            </div>

                            {/* Subcategories Section */}
                            <div className="border-t border-gray-200 pt-6">
                              <h6 className="text-lg font-bold text-gray-900 mb-4">Subcategories ({(category.subcategories || []).length})</h6>

                              {/* Add Subcategory Form */}
                              {selectedCategoryForSubcategory === category.id && !editingSubcategory && (
                                <div className="bg-white rounded-lg p-4 mb-4 border border-teal-200">
                                  <h6 className="font-bold text-gray-900 mb-4">Add New Subcategory</h6>
                                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <input
                                      type="text"
                                      placeholder="Subcategory name"
                                      value={subcategoryForm.name}
                                      onChange={(e) => setSubcategoryForm({ ...subcategoryForm, name: e.target.value })}
                                      className="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-500"
                                    />

                                    <input
                                      type="text"
                                      placeholder="Description"
                                      value={subcategoryForm.description}
                                      onChange={(e) => setSubcategoryForm({ ...subcategoryForm, description: e.target.value })}
                                      className="md:col-span-2 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-teal-500"
                                    />
                                  </div>
                                  <div className="flex gap-2 mt-4">
                                    <button
                                      onClick={() => handleCreateSubcategory(category.id)}
                                      className="px-4 py-2 bg-teal-600 text-white rounded-lg font-semibold hover:bg-teal-700 transition text-sm"
                                    >
                                      Create Subcategory
                                    </button>
                                    <button
                                      onClick={() => {
                                        setSelectedCategoryForSubcategory(null)
                                        setSubcategoryForm({ name: '', description: '', icon: '', image: '' })
                                      }}
                                      className="px-4 py-2 bg-gray-400 text-white rounded-lg font-semibold hover:bg-gray-500 transition text-sm"
                                    >
                                      Cancel
                                    </button>
                                  </div>
                                </div>
                              )}

                              {/* Subcategories List */}
                              {(category.subcategories || []).length === 0 ? (
                                <p className="text-sm text-gray-600 mb-4">No subcategories yet.</p>
                              ) : (
                                <div className="space-y-3 mb-4">
                                  {(category.subcategories || []).map((subcategory) => (
                                    <div key={subcategory.id} className="bg-white p-4 rounded-lg border border-gray-200 flex justify-between items-center">
                                      <div className="flex-1">
                                        <p className="font-semibold text-gray-900">{subcategory.name}</p>
                                        {subcategory.description && <p className="text-sm text-gray-600">{subcategory.description}</p>}
                                      </div>
                                      <div className="flex gap-2">
                                        <button
                                          onClick={() => {
                                            setEditingSubcategory(subcategory.id)
                                            setSubcategoryForm({
                                              name: subcategory.name,
                                              description: subcategory.description || '',
                                              icon: subcategory.icon || '',
                                              image: subcategory.image || ''
                                            })
                                          }}
                                          className="px-3 py-1 bg-blue-500 text-white rounded text-xs font-semibold hover:bg-blue-600 transition"
                                        >
                                          Edit
                                        </button>
                                        <button
                                          onClick={() => handleDeleteSubcategory(category.id, subcategory.id)}
                                          className="px-3 py-1 bg-red-500 text-white rounded text-xs font-semibold hover:bg-red-600 transition"
                                        >
                                          Delete
                                        </button>
                                      </div>
                                    </div>
                                  ))}
                                </div>
                              )}

                              {/* Add Subcategory Button */}
                              {selectedCategoryForSubcategory !== category.id && (
                                <button
                                  onClick={() => {
                                    setSelectedCategoryForSubcategory(category.id)
                                    setSubcategoryForm({ name: '', description: '', icon: '', image: '' })
                                  }}
                                  className="px-4 py-2 bg-emerald-600 text-white rounded-lg font-semibold hover:bg-emerald-700 transition text-sm"
                                >
                                  + Add Subcategory
                                </button>
                              )}
                            </div>
                          </div>
                        )}
                      </div>
                    ))
                  )}
                </div>
              </div>
            )}

            {/* Post Product to Vendor Store Tab */}
            {activeTab === 'post-product' && (
              <div className="space-y-8">
                <div>
                  <h3 className="text-2xl font-bold text-gray-900 mb-2">Post Product to Vendor Store</h3>
                  <p className="text-gray-600">Help vendors by posting products directly to their stores</p>
                </div>

                <div className="bg-white rounded-xl shadow-md p-8 border border-gray-200">
                  <h4 className="text-xl font-bold text-gray-900 mb-6">Create and Post Product</h4>
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div className="md:col-span-2">
                      <label className="block text-sm font-bold text-gray-700 mb-2">Select Vendor Store *</label>
                      <select
                        value={postProductForm.storeId}
                        onChange={(e) => setPostProductForm({ ...postProductForm, storeId: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent"
                      >
                        <option value="">Choose a vendor store...</option>
                        {vendorStores.map(store => (
                          <option key={store.id} value={store.id}>{store.name} ({store.city})</option>
                        ))}
                      </select>
                    </div>

                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Product Name *</label>
                      <input
                        type="text"
                        placeholder="e.g., 5KVA Solar Inverter"
                        value={postProductForm.name}
                        onChange={(e) => setPostProductForm({ ...postProductForm, name: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent"
                      />
                    </div>

                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Price *</label>
                      <input
                        type="number"
                        placeholder="50000"
                        value={postProductForm.price}
                        onChange={(e) => setPostProductForm({ ...postProductForm, price: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent"
                      />
                    </div>

                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Stock Quantity *</label>
                      <input
                        type="number"
                        placeholder="10"
                        value={postProductForm.stock}
                        onChange={(e) => setPostProductForm({ ...postProductForm, stock: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent"
                      />
                    </div>

                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Category *</label>
                      <select
                        value={postProductForm.category}
                        onChange={(e) => setPostProductForm({ ...postProductForm, category: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent"
                      >
                        <option value="">Select a category...</option>
                        {categories.map(cat => (
                          <option key={cat.id} value={cat.id}>{cat.name}</option>
                        ))}
                      </select>
                    </div>

                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Subcategory</label>
                      <select
                        value={postProductForm.subcategory}
                        onChange={(e) => setPostProductForm({ ...postProductForm, subcategory: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent"
                      >
                        <option value="">Select subcategory (optional)...</option>
                        {postProductForm.category && categories.find(c => c.id === postProductForm.category)?.subcategories?.map(subcat => (
                          <option key={subcat.id} value={subcat.id}>{subcat.name}</option>
                        ))}
                      </select>
                    </div>

                    <div className="md:col-span-2">
                      <label className="block text-sm font-bold text-gray-700 mb-2">Description *</label>
                      <textarea
                        placeholder="Detailed product description"
                        value={postProductForm.description}
                        onChange={(e) => setPostProductForm({ ...postProductForm, description: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent h-24"
                      />
                    </div>

                    <div className="md:col-span-2">
                      <label className="block text-sm font-bold text-gray-700 mb-2">Product Image * (Upload to S3)</label>
                      <S3ImageUploader
                        folder="admin-products"
                        maxImages={1}
                        onUploadComplete={(urls) => {
                          console.log('[ADMIN DASHBOARD] Product image uploaded:', urls);
                          if (urls.length > 0) {
                            setPostProductForm({ ...postProductForm, image: urls[0] })
                          }
                        }}
                        onError={(error) => {
                          console.error('[ADMIN DASHBOARD] Image upload error:', error);
                          alert(`Image upload failed: ${error.message}`)
                        }}
                      />
                      {postProductForm.image && (
                        <div className="mt-3">
                          <p className="text-xs text-gray-600 font-bold mb-2">✓ Image uploaded to S3:</p>
                          <div className="relative w-32 h-32 bg-gray-100 rounded border overflow-hidden">
                            <img src={postProductForm.image} alt="Product" className="w-full h-full object-cover" />
                            <button
                              type="button"
                              onClick={() => setPostProductForm({ ...postProductForm, image: '' })}
                              className="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center text-xs hover:bg-red-600 z-10"
                              title="Remove image"
                            >
                              ×
                            </button>
                          </div>
                        </div>
                      )}
                    </div>
                  </div>

                  <div className="flex gap-4 mt-8">
                    <button
                      onClick={handlePostProduct}
                      disabled={postingProduct}
                      className="flex-1 px-6 py-2 bg-teal-600 text-white rounded-lg font-semibold hover:bg-teal-700 transition disabled:opacity-50"
                    >
                      {postingProduct ? 'Posting...' : '✓ Post Product to Store'}
                    </button>
                    <button
                      onClick={() => setPostProductForm({
                        name: '',
                        description: '',
                        price: '',
                        image: '',
                        category: '',
                        subcategory: '',
                        stock: '',
                        storeId: ''
                      })}
                      className="px-6 py-2 bg-gray-400 text-white rounded-lg font-semibold hover:bg-gray-500 transition"
                    >
                      Clear
                    </button>
                  </div>
                </div>
              </div>
            )}

            {/* Flash Deals (Solar Packages) Tab */}
            {activeTab === 'flash-deals' && (
              <div className="space-y-8">
                <div>
                  <h3 className="text-2xl font-bold text-gray-900 mb-2">🔥 Post Flash Deals (Solar Packages)</h3>
                  <p className="text-gray-600">Create and post predefined solar packages for quick vendor promotions</p>
                </div>

                <div className="bg-white rounded-xl shadow-md p-8 border border-gray-200">
                  <h4 className="text-xl font-bold text-gray-900 mb-6">Create Solar Package Deal</h4>
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div className="md:col-span-2">
                      <label className="block text-sm font-bold text-gray-700 mb-2">Select Vendor Store *</label>
                      <select
                        value={flashDealForm.storeId}
                        onChange={(e) => setFlashDealForm({ ...flashDealForm, storeId: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
                      >
                        <option value="">Choose a vendor store...</option>
                        {vendorStores.map(store => (
                          <option key={store.id} value={store.id}>{store.name} ({store.city})</option>
                        ))}
                      </select>
                    </div>

                    <div className="md:col-span-2">
                      <label className="block text-sm font-bold text-gray-700 mb-2">Select Package Type *</label>
                      <select
                        value={flashDealForm.selectedPackageName}
                        onChange={(e) => {
                          const pkg = e.target.value
                          setFlashDealForm({ ...flashDealForm, selectedPackageName: pkg })
                          if (pkg.includes('Hybrid')) {
                            setFlashDealForm(prev => ({ ...prev, inverterType: 'hybrid' }))
                          } else {
                            setFlashDealForm(prev => ({ ...prev, inverterType: 'standard' }))
                          }
                        }}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
                      >
                        <option value="">Choose a package...</option>
                        <option value="Starter Backup (No Panel)">Starter Backup (No Panel) - 0 panels</option>
                        <option value="Starter Backup Package">Starter Backup Package - 1-2 panels</option>
                        <option value="Apartment Essential Package">Apartment Essential Package - 2-3 panels</option>
                        <option value="Family Home Package">Family Home Package - 3-5 panels</option>
                        <option value="Premium Home Package">Premium Home Package - 6-8 panels</option>
                        <option value="Hybrid Smart Home Package">Hybrid Smart Home Package - 8-12 panels (Hybrid Inverter)</option>
                        <option value="Retail Store Package">Retail Store Package - 3-4 panels</option>
                        <option value="Small Office Package">Small Office Package - 4-6 panels</option>
                        <option value="Medium Office Package">Medium Office Package - 6-10 panels</option>
                      </select>
                    </div>

                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Battery Type *</label>
                      <select
                        value={flashDealForm.batteryType}
                        onChange={(e) => setFlashDealForm({ ...flashDealForm, batteryType: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
                      >
                        <option value="lithium">🔋 Lithium (3-5 years warranty)</option>
                        <option value="tubular">🪫 Tubular (1-2 years warranty)</option>
                      </select>
                    </div>

                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Inverter Type *</label>
                      <select
                        value={flashDealForm.inverterType}
                        onChange={(e) => setFlashDealForm({ ...flashDealForm, inverterType: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
                      >
                        <option value="standard">⚙️ Standard Inverter</option>
                        <option value="hybrid">⚡ Hybrid Inverter (Smart Home)</option>
                      </select>
                    </div>

                    <div>
                      <label className="block text-sm font-bold text-gray-700 mb-2">Package Price *</label>
                      <input
                        type="number"
                        placeholder="500000"
                        value={flashDealForm.price}
                        onChange={(e) => setFlashDealForm({ ...flashDealForm, price: e.target.value })}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
                      />
                    </div>

                    <div className="md:col-span-2">
                      <label className="block text-sm font-bold text-gray-700 mb-2">Powers Included</label>
                      <textarea
                        value={flashDealForm.powers}
                        onChange={(e) => setFlashDealForm({ ...flashDealForm, powers: e.target.value })}
                        rows={2}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
                      />
                    </div>

                    <div className="md:col-span-2">
                      <label className="block text-sm font-bold text-gray-700 mb-2">Warranty Coverage</label>
                      <textarea
                        value={flashDealForm.warranty}
                        onChange={(e) => setFlashDealForm({ ...flashDealForm, warranty: e.target.value })}
                        rows={2}
                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
                      />
                    </div>

                    {/* Flash Deal Images Upload */}
                    <div className="md:col-span-2">
                      <label className="block text-sm font-bold text-gray-700 mb-2">Flash Deal Images (Optional - Upload to S3)</label>
                      <S3ImageUploader
                        folder="admin-flash-deals"
                        maxImages={5}
                        onUploadComplete={(urls) => {
                          console.log('[ADMIN DASHBOARD] Flash deal images uploaded:', urls);
                          setFlashDealForm(prev => ({ ...prev, images: urls }))
                        }}
                        onError={(error) => {
                          console.error('[ADMIN DASHBOARD] Flash deal image upload error:', error);
                          alert(`Image upload failed: ${error.message}`)
                        }}
                      />
                      
                      {/* Display uploaded image previews */}
                      {flashDealForm.images.length > 0 && (
                        <div className="mt-3">
                          <p className="text-xs text-gray-600 font-bold mb-2">✓ {flashDealForm.images.length} image(s) uploaded to S3:</p>
                          <div className="grid grid-cols-4 gap-2">
                            {flashDealForm.images.map((url, index) => (
                              <div key={index} className="relative aspect-square bg-gray-100 rounded border overflow-hidden">
                                <img src={url} alt={`Deal ${index + 1}`} className="w-full h-full object-cover rounded" />
                                <button
                                  type="button"
                                  onClick={() => {
                                    const updated = flashDealForm.images.filter((_, i) => i !== index)
                                    setFlashDealForm(prev => ({ ...prev, images: updated }))
                                  }}
                                  className="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center text-xs hover:bg-red-600 z-10"
                                  title="Remove image"
                                >
                                  ×
                                </button>
                              </div>
                            ))}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>

                  {/* Package Summary */}
                  <div className="bg-red-50 border-2 border-red-200 rounded-lg p-4 my-6">
                    <h3 className="font-bold mb-3 text-red-900">📦 Package Summary:</h3>
                    <ul className="space-y-2 text-sm text-gray-900">
                      <li><span className="text-green-600 font-bold">✓</span> <span className="font-semibold">Package:</span> {flashDealForm.selectedPackageName || '(Select a package)'}</li>
                      <li><span className="text-green-600 font-bold">✓</span> <span className="font-semibold">Battery:</span> {flashDealForm.batteryType === 'lithium' ? 'Lithium (3-5 yrs)' : 'Tubular (1-2 yrs)'}</li>
                      <li><span className="text-green-600 font-bold">✓</span> <span className="font-semibold">Inverter:</span> {flashDealForm.inverterType === 'hybrid' ? 'Hybrid (Smart Home)' : 'Standard'}</li>
                      <li><span className="text-green-600 font-bold">✓</span> <span className="font-semibold">Price:</span> {formatPrice(parseFloat(flashDealForm.price) || 0)}</li>
                    </ul>
                  </div>

                  <div className="flex gap-4">
                    <button
                      onClick={handlePostFlashDeal}
                      disabled={postingFlashDeal}
                      className="flex-1 px-6 py-2 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700 transition disabled:opacity-50"
                    >
                      {postingFlashDeal ? 'Posting...' : '🔥 Post Flash Deal'}
                    </button>
                    <button
                      onClick={() => setFlashDealForm({
                        selectedPackageName: '',
                        batteryType: 'lithium',
                        inverterType: 'standard',
                        powers: '3 bedrooms, lights, fan, TV, decoder, phone charging',
                        warranty: 'Panels (10–25 yrs) • Inverter (1–2 yrs) • Battery — Lithium (3–5 yrs) / Tubular (1–2 yrs) • Installation kit (1 yr)',
                        price: '',
                        storeId: '',
                        images: []
                      })}
                      className="px-6 py-2 bg-gray-400 text-white rounded-lg font-semibold hover:bg-gray-500 transition"
                    >
                      Clear
                    </button>
                  </div>
                </div>

                {/* Manage Posted Flash Deals */}
                <div className="bg-white rounded-xl shadow-md p-8 border border-gray-200">
                  <h4 className="text-xl font-bold text-gray-900 mb-6">📋 Manage Posted Flash Deals</h4>

                  {flashDeals.length === 0 ? (
                    <div className="bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center">
                      <p className="text-yellow-800 font-semibold">No flash deals posted yet</p>
                    </div>
                  ) : (
                    <div className="overflow-x-auto">
                      <table className="w-full">
                        <thead className="bg-gray-100 border-b-2 border-gray-300">
                          <tr>
                            <th className="px-4 py-3 text-left font-bold text-gray-900">Package Name</th>
                            <th className="px-4 py-3 text-left font-bold text-gray-900">Store</th>
                            <th className="px-4 py-3 text-left font-bold text-gray-900">Price</th>
                            <th className="px-4 py-3 text-left font-bold text-gray-900">Battery Type</th>
                            <th className="px-4 py-3 text-center font-bold text-gray-900">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          {flashDeals.map((deal: any) => (
                            <tr key={deal.id} className="border-b hover:bg-gray-50">
                              <td className="px-4 py-3 text-gray-900 font-semibold">{deal.name}</td>
                              <td className="px-4 py-3 text-gray-700">{deal.store?.name || 'N/A'}</td>
                              <td className="px-4 py-3 text-gray-900 font-bold">{formatPrice(deal.vendorPrice || 0)}</td>
                              <td className="px-4 py-3 text-gray-700">{deal.category === 'lithium' ? '🔋 Lithium' : deal.category === 'tubular' ? '🪫 Tubular' : deal.category}</td>
                              <td className="px-4 py-3 flex gap-2 justify-center">
                                <button
                                  onClick={() => handleEditFlashDeal(deal)}
                                  className="px-3 py-1 bg-blue-500 text-white text-sm rounded hover:bg-blue-600 transition"
                                >
                                  ✏️ Edit
                                </button>
                                <button
                                  onClick={() => handleDeleteFlashDeal(deal.id)}
                                  className="px-3 py-1 bg-red-600 text-white text-sm rounded hover:bg-red-700 transition"
                                >
                                  🗑️ Delete
                                </button>
                              </td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  )}

                  {/* Edit Flash Deal Modal */}
                  {editingFlashDealId && editFlashDealForm && (
                    <div className="mt-8 bg-blue-50 border-2 border-blue-300 rounded-lg p-6">
                      <h4 className="text-lg font-bold text-gray-900 mb-4">✏️ Edit Flash Deal: {editFlashDealForm.selectedPackageName}</h4>
                      
                      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                          <label className="block text-sm font-bold text-gray-700 mb-1">Package Name</label>
                          <input
                            type="text"
                            value={editFlashDealForm.selectedPackageName}
                            onChange={(e) => setEditFlashDealForm({ ...editFlashDealForm, selectedPackageName: e.target.value })}
                            className="w-full px-3 py-2 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500"
                          />
                        </div>

                        <div>
                          <label className="block text-sm font-bold text-gray-700 mb-1">Price</label>
                          <input
                            type="number"
                            value={editFlashDealForm.price}
                            onChange={(e) => setEditFlashDealForm({ ...editFlashDealForm, price: e.target.value })}
                            className="w-full px-3 py-2 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500"
                          />
                        </div>

                        <div>
                          <label className="block text-sm font-bold text-gray-700 mb-1">Battery Type</label>
                          <select
                            value={editFlashDealForm.batteryType}
                            onChange={(e) => setEditFlashDealForm({ ...editFlashDealForm, batteryType: e.target.value })}
                            className="w-full px-3 py-2 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500"
                          >
                            <option value="lithium">🔋 Lithium</option>
                            <option value="tubular">🪫 Tubular</option>
                          </select>
                        </div>

                        <div>
                          <label className="block text-sm font-bold text-gray-700 mb-1">Inverter Type</label>
                          <select
                            value={editFlashDealForm.inverterType}
                            onChange={(e) => setEditFlashDealForm({ ...editFlashDealForm, inverterType: e.target.value })}
                            className="w-full px-3 py-2 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500"
                          >
                            <option value="standard">⚙️ Standard</option>
                            <option value="hybrid">⚡ Hybrid</option>
                          </select>
                        </div>

                        <div className="md:col-span-2">
                          <label className="block text-sm font-bold text-gray-700 mb-1">Powers</label>
                          <textarea
                            value={editFlashDealForm.powers}
                            onChange={(e) => setEditFlashDealForm({ ...editFlashDealForm, powers: e.target.value })}
                            rows={2}
                            className="w-full px-3 py-2 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500"
                          />
                        </div>

                        <div className="md:col-span-2">
                          <label className="block text-sm font-bold text-gray-700 mb-1">Warranty</label>
                          <textarea
                            value={editFlashDealForm.warranty}
                            onChange={(e) => setEditFlashDealForm({ ...editFlashDealForm, warranty: e.target.value })}
                            rows={2}
                            className="w-full px-3 py-2 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500"
                          />
                        </div>
                      </div>

                      <div className="flex gap-3 mt-4">
                        <button
                          onClick={handleSaveFlashDeal}
                          disabled={savingFlashDeal}
                          className="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition disabled:opacity-50"
                        >
                          {savingFlashDeal ? '💾 Saving...' : '💾 Save Changes'}
                        </button>
                        <button
                          onClick={() => {
                            setEditingFlashDealId(null)
                            setEditFlashDealForm(null)
                          }}
                          className="flex-1 px-4 py-2 bg-gray-400 text-white rounded-lg font-semibold hover:bg-gray-500 transition"
                        >
                          ✕ Cancel
                        </button>
                      </div>
                    </div>
                  )}
                </div>
              </div>
            )}

            {/* Flash Deals Orders Management */}
            {activeTab === 'flash-deals' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">🔥 Flash Deals Orders</h3>
                {orders.length === 0 ? (
                  <p className="text-gray-600">No flash deals orders found</p>
                ) : (
                  <div className="space-y-4">
                    {orders
                      .filter(order => order.items && order.items.some((item: any) => item.isFlashDeal || item.packageType))
                      .map((order) => {
                        const currentDeliveryStatus = orderStatusChanges[order.id]?.deliveryStatus || order.orderStatus || 'pending'
                        const currentPaymentStatus = orderStatusChanges[order.id]?.paymentStatus || order.paymentStatus || 'pending'
                        const isRefunded = refundedOrders.has(order.id)

                        return (
                          <div key={order.id} className="bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-lg transition-shadow p-6 border border-gray-100 dark:border-gray-700">
                            
                            {/* Header: Order ID, Date, Status */}
                            <div className="flex justify-between items-start mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">
                              <div>
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide">Order ID</p>
                                <p className="font-mono font-bold text-sm text-gray-900 dark:text-white mt-1">{order.orderNumber || order.id.slice(0, 12)}...</p>
                              </div>
                              <div className="text-center">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide">Date</p>
                                <p className="font-bold text-gray-900 dark:text-white mt-1">{new Date(order.createdAt).toLocaleDateString()}</p>
                              </div>
                              <div className="text-right">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Status</p>
                                <div className="flex gap-2 justify-end flex-wrap">
                                  <span className={`px-3 py-1 rounded text-xs font-bold ${
                                    currentDeliveryStatus === 'delivered' ? 'bg-green-100 text-green-800' :
                                    currentDeliveryStatus === 'shipped' ? 'bg-blue-100 text-blue-800' :
                                    'bg-orange-100 text-orange-800'
                                  }`}>
                                    {currentDeliveryStatus}
                                  </span>
                                  <span className={`px-3 py-1 rounded text-xs font-bold ${
                                    isRefunded || currentPaymentStatus === 'refunded' ? 'bg-red-100 text-red-800' :
                                    currentPaymentStatus === 'paid' || currentPaymentStatus === 'completed' ? 'bg-green-100 text-green-800' :
                                    'bg-orange-100 text-orange-800'
                                  }`}>
                                    {isRefunded ? 'refunded' : currentPaymentStatus}
                                  </span>
                                </div>
                              </div>
                            </div>

                            {/* Items Ordered */}
                            <div className="mb-6">
                              <p className="font-bold text-gray-900 dark:text-white mb-4">Items Ordered</p>
                              <div className="space-y-4">
                                {order.items && order.items.length > 0 ? (
                                  order.items.map((item: any, idx: number) => {
                                    const product = item.product || {} as any
                                    const productImage = product.image || item.image || ''
                                    const productName = product.name || item.name || item.packageName || 'Flash Deal Package'
                                    
                                    return (
                                      <div key={idx} className="flex gap-4 items-start">
                                        <div className="w-16 h-16 rounded-md bg-gray-100 flex-shrink-0 overflow-hidden flex items-center justify-center">
                                          {productImage ? (
                                            <img src={productImage} alt={productName} className="w-full h-full object-cover" onError={(e) => {
                                              (e.target as HTMLImageElement).src = '/placeholder.png'
                                            }} />
                                          ) : (
                                            <span className="text-xl">🔥</span>
                                          )}
                                        </div>
                                        <div className="flex-1 flex justify-between items-start">
                                          <div>
                                            <p className="font-bold text-gray-900 dark:text-white">{productName}</p>
                                            <p className="text-sm text-gray-600 dark:text-gray-400 mt-1">Qty: {item.quantity} | Price: ₦{(item.price || 0).toLocaleString()}</p>
                                          </div>
                                          <div className="text-right flex-shrink-0 ml-4">
                                            <p className="text-xs text-gray-600 dark:text-gray-400 font-bold mb-1">Subtotal</p>
                                            <p className="font-bold text-green-600 dark:text-green-400">₦{((item.price || 0) * (item.quantity || 1)).toLocaleString()}</p>
                                          </div>
                                        </div>
                                      </div>
                                    )
                                  })
                                ) : (
                                  <p className="text-gray-500 dark:text-gray-400 italic">No items in this order</p>
                                )}
                              </div>
                            </div>

                            {/* Customer & Total */}
                            <div className="flex justify-between items-start pt-4 border-t border-gray-200 dark:border-gray-700 mb-4">
                              <div>
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Customer</p>
                                <p className="font-bold text-gray-900 dark:text-white">{order.customer?.fullName || 'N/A'}</p>
                                <p className="text-sm text-gray-600 dark:text-gray-400">{order.customer?.email || 'N/A'}</p>
                              </div>
                              <div className="text-right flex-shrink-0">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Total</p>
                                <p className="text-3xl font-bold text-green-600 dark:text-green-400">₦{(order.totalPrice || order.total || 0).toLocaleString()}</p>
                              </div>
                            </div>

                            {/* Update Order Status Button */}
                            <div className="pt-6 mt-6 border-t-2 border-emerald-400">
                              <button
                                onClick={() => {
                                  setUpdatingOrderId(order.id)
                                  setNewOrderStatus(order.orderStatus || 'pending')
                                  setUpdateStatusError('')
                                }}
                                className="w-full px-6 py-4 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white font-bold rounded-lg transition text-base shadow-lg hover:shadow-xl"
                              >
                                📝 Update Order Status
                              </button>
                            </div>

                            {/* Refund Button */}
                            {currentPaymentStatus === 'paid' && (
                              <div className="pt-4 border-t border-gray-200 dark:border-gray-700">
                                {isRefunded ? (
                                  <button disabled className="w-full px-4 py-2 bg-red-100 text-red-800 font-bold rounded-lg opacity-75 cursor-not-allowed">
                                    ✓ Refunded
                                  </button>
                                ) : (
                                  <button
                                    onClick={() => setRefundConfirmOrderId(order.id)}
                                    className="w-full px-4 py-2 bg-red-600 hover:bg-red-700 active:bg-red-800 text-white font-bold rounded-lg transition"
                                  >
                                    💰 Process Refund
                                  </button>
                                )}
                              </div>
                            )}
                          </div>
                        )
                      })}
                    {orders.every(order => !order.items || !order.items.some((item: any) => item.isFlashDeal || item.packageType)) && (
                      <p className="text-gray-600 italic text-center py-8">No flash deals orders found</p>
                    )}
                  </div>
                )}
              </div>
            )}

            {/* Swap/Resell Orders Management */}
            {activeTab === 'swap-resell' && (
              <div>
                <h3 className="text-2xl font-bold text-gray-900 mb-6">🔄 Swap/Resell Orders</h3>
                {orders.length === 0 ? (
                  <p className="text-gray-600">No swap/resell orders found</p>
                ) : (
                  <div className="space-y-4">
                    {orders
                      .filter(order => order.items && order.items.some((item: any) => item.isSwapResell || item.condition === 'used' || item.condition === 'refurbished'))
                      .map((order) => {
                        const currentDeliveryStatus = orderStatusChanges[order.id]?.deliveryStatus || order.orderStatus || 'pending'
                        const currentPaymentStatus = orderStatusChanges[order.id]?.paymentStatus || order.paymentStatus || 'pending'
                        const isRefunded = refundedOrders.has(order.id)

                        return (
                          <div key={order.id} className="bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-lg transition-shadow p-6 border border-gray-100 dark:border-gray-700">
                            
                            {/* Header: Order ID, Date, Status */}
                            <div className="flex justify-between items-start mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">
                              <div>
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide">Order ID</p>
                                <p className="font-mono font-bold text-sm text-gray-900 dark:text-white mt-1">{order.orderNumber || order.id.slice(0, 12)}...</p>
                              </div>
                              <div className="text-center">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide">Date</p>
                                <p className="font-bold text-gray-900 dark:text-white mt-1">{new Date(order.createdAt).toLocaleDateString()}</p>
                              </div>
                              <div className="text-right">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Status</p>
                                <div className="flex gap-2 justify-end flex-wrap">
                                  <span className={`px-3 py-1 rounded text-xs font-bold ${
                                    currentDeliveryStatus === 'delivered' ? 'bg-green-100 text-green-800' :
                                    currentDeliveryStatus === 'shipped' ? 'bg-blue-100 text-blue-800' :
                                    'bg-orange-100 text-orange-800'
                                  }`}>
                                    {currentDeliveryStatus}
                                  </span>
                                  <span className={`px-3 py-1 rounded text-xs font-bold ${
                                    isRefunded || currentPaymentStatus === 'refunded' ? 'bg-red-100 text-red-800' :
                                    currentPaymentStatus === 'paid' || currentPaymentStatus === 'completed' ? 'bg-green-100 text-green-800' :
                                    'bg-orange-100 text-orange-800'
                                  }`}>
                                    {isRefunded ? 'refunded' : currentPaymentStatus}
                                  </span>
                                </div>
                              </div>
                            </div>

                            {/* Items Ordered */}
                            <div className="mb-6">
                              <p className="font-bold text-gray-900 dark:text-white mb-4">Items Ordered</p>
                              <div className="space-y-4">
                                {order.items && order.items.length > 0 ? (
                                  order.items.map((item: any, idx: number) => {
                                    const product = item.product || {} as any
                                    const productImage = product.image || item.image || ''
                                    const productName = product.name || item.name || 'Swap/Resell Item'
                                    const condition = item.condition || 'used'
                                    
                                    return (
                                      <div key={idx} className="flex gap-4 items-start">
                                        <div className="w-16 h-16 rounded-md bg-gray-100 flex-shrink-0 overflow-hidden flex items-center justify-center relative">
                                          {productImage ? (
                                            <img src={productImage} alt={productName} className="w-full h-full object-cover" onError={(e) => {
                                              (e.target as HTMLImageElement).src = '/placeholder.png'
                                            }} />
                                          ) : (
                                            <span className="text-xl">♻️</span>
                                          )}
                                          <span className="absolute -top-2 -right-2 bg-amber-500 text-white text-xs px-2 py-1 rounded font-bold">{condition}</span>
                                        </div>
                                        <div className="flex-1 flex justify-between items-start">
                                          <div>
                                            <p className="font-bold text-gray-900 dark:text-white">{productName}</p>
                                            <p className="text-sm text-gray-600 dark:text-gray-400 mt-1">Qty: {item.quantity} | Price: ₦{(item.price || 0).toLocaleString()}</p>
                                          </div>
                                          <div className="text-right flex-shrink-0 ml-4">
                                            <p className="text-xs text-gray-600 dark:text-gray-400 font-bold mb-1">Subtotal</p>
                                            <p className="font-bold text-green-600 dark:text-green-400">₦{((item.price || 0) * (item.quantity || 1)).toLocaleString()}</p>
                                          </div>
                                        </div>
                                      </div>
                                    )
                                  })
                                ) : (
                                  <p className="text-gray-500 dark:text-gray-400 italic">No items in this order</p>
                                )}
                              </div>
                            </div>

                            {/* Customer & Total */}
                            <div className="flex justify-between items-start pt-4 border-t border-gray-200 dark:border-gray-700 mb-4">
                              <div>
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Customer</p>
                                <p className="font-bold text-gray-900 dark:text-white">{order.customer?.fullName || 'N/A'}</p>
                                <p className="text-sm text-gray-600 dark:text-gray-400">{order.customer?.email || 'N/A'}</p>
                              </div>
                              <div className="text-right flex-shrink-0">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Total</p>
                                <p className="text-3xl font-bold text-green-600 dark:text-green-400">₦{(order.totalPrice || order.total || 0).toLocaleString()}</p>
                              </div>
                            </div>

                            {/* Update Order Status Button */}
                            <div className="pt-6 mt-6 border-t-2 border-emerald-400">
                              <button
                                onClick={() => {
                                  setUpdatingOrderId(order.id)
                                  setNewOrderStatus(order.orderStatus || 'pending')
                                  setUpdateStatusError('')
                                }}
                                className="w-full px-6 py-4 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white font-bold rounded-lg transition text-base shadow-lg hover:shadow-xl"
                              >
                                📝 Update Order Status
                              </button>
                            </div>

                            {/* Refund Button */}
                            {currentPaymentStatus === 'paid' && (
                              <div className="pt-4 border-t border-gray-200 dark:border-gray-700">
                                {isRefunded ? (
                                  <button disabled className="w-full px-4 py-2 bg-red-100 text-red-800 font-bold rounded-lg opacity-75 cursor-not-allowed">
                                    ✓ Refunded
                                  </button>
                                ) : (
                                  <button
                                    onClick={() => setRefundConfirmOrderId(order.id)}
                                    className="w-full px-4 py-2 bg-red-600 hover:bg-red-700 active:bg-red-800 text-white font-bold rounded-lg transition"
                                  >
                                    💰 Process Refund
                                  </button>
                                )}
                              </div>
                            )}
                          </div>
                        )
                      })}
                    {orders.every(order => !order.items || !order.items.some((item: any) => item.isSwapResell || item.condition === 'used' || item.condition === 'refurbished')) && (
                      <p className="text-gray-600 italic text-center py-8">No swap/resell orders found</p>
                    )}
                  </div>
                )}
              </div>
            )}

            {/* Installments Management */}
            {activeTab === 'installments' && (
              <div>
                <div className="flex justify-between items-center mb-6">
                  <div>
                    <h3 className="text-2xl font-bold text-gray-900 mb-2">📦💳 Installment Orders (Pay Small Small)</h3>
                    <p className="text-gray-600">Manage all installment payment plans and approvals</p>
                  </div>
                </div>

                {installments.length === 0 ? (
                  <div className="bg-white rounded-lg shadow-md p-8 text-center">
                    <p className="text-gray-600">No installment orders found</p>
                  </div>
                ) : (
                  <div className="space-y-6">
                    {installments.map((installment: any) => {
                      const totalAmount = parseFloat(installment.totalAmount || 0)
                      const paidAmount = parseFloat(installment.paidAmount || 0)
                      const remainingBalance = totalAmount - paidAmount
                      const progressPercentage = totalAmount > 0 ? (paidAmount / totalAmount) * 100 : 0
                      const firstPayment = totalAmount * 0.5
                      const monthlyPayment = parseFloat(installment.monthlyAmount || 0)

                      return (
                        <div key={installment.id} className="bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-lg transition-shadow border border-gray-100 dark:border-gray-700 overflow-hidden">
                          
                          {/* Header Section */}
                          <div className="bg-gradient-to-r from-cyan-500 to-teal-600 text-white p-6">
                            <div className="flex justify-between items-start">
                              <div>
                                <div className="flex items-center gap-2 mb-2">
                                  <span className="text-2xl">💾</span>
                                  <span className="text-xs font-bold uppercase tracking-wider opacity-90">Installment ID</span>
                                </div>
                                <p className="font-mono text-lg font-bold">{installment.id.substring(0, 12)}...</p>
                              </div>
                              <div className="text-right">
                                <p className="text-xs font-bold uppercase tracking-wider opacity-90 mb-1">Payment Plan</p>
                                <p className="text-2xl font-bold">{installment.paymentPlan}</p>
                              </div>
                            </div>
                          </div>

                          {/* Buyer Information Section */}
                          <div className="p-6 border-b border-gray-200 dark:border-gray-700">
                            <h4 className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-4">👤 Buyer Information</h4>
                            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                              <div>
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-1">Name</p>
                                <p className="font-bold text-gray-900 dark:text-white">{installment.customerName || 'N/A'}</p>
                              </div>
                              <div>
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-1">Email</p>
                                <p className="font-semibold text-gray-900 dark:text-white text-sm">{installment.customerEmail || 'N/A'}</p>
                              </div>
                              <div>
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-1">Phone</p>
                                <p className="font-semibold text-gray-900 dark:text-white">{installment.user?.phone || 'N/A'}</p>
                              </div>
                              <div>
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-1">Address</p>
                                <p className="font-semibold text-gray-900 dark:text-white text-sm">{installment.user?.city || 'N/A'}</p>
                              </div>
                            </div>
                          </div>

                          {/* Order Details Section */}
                          <div className="p-6 border-b border-gray-200 dark:border-gray-700">
                            <h4 className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-4">📦 Products Ordered</h4>
                            {installment.order && installment.order.items && installment.order.items.length > 0 ? (
                              <div className="space-y-4">
                                {installment.order.items.map((item: any, idx: number) => (
                                  <div key={idx} className="flex gap-4 items-start bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
                                    {/* Product Image */}
                                    <div className="w-20 h-20 rounded-lg bg-gray-100 dark:bg-gray-600 flex-shrink-0 overflow-hidden flex items-center justify-center">
                                      {item.product?.image || item.image ? (
                                        <img 
                                          src={item.product?.image || item.image} 
                                          alt={item.product?.name || item.name}
                                          className="w-full h-full object-cover"
                                          onError={(e) => {
                                            (e.target as HTMLImageElement).src = '/placeholder.png'
                                          }}
                                        />
                                      ) : (
                                        <span className="text-2xl">📦</span>
                                      )}
                                    </div>

                                    {/* Product Details */}
                                    <div className="flex-1">
                                      <p className="font-bold text-gray-900 dark:text-white">{item.product?.name || item.name || 'Unknown Product'}</p>
                                      <p className="text-sm text-gray-600 dark:text-gray-400 mt-1">
                                        <span className="font-semibold">Qty:</span> {item.quantity} | <span className="font-semibold">Unit Price:</span> ₦{(item.price || 0).toLocaleString()}
                                      </p>
                                      {item.product?.description && (
                                        <p className="text-xs text-gray-600 dark:text-gray-400 mt-2">{item.product.description.substring(0, 100)}...</p>
                                      )}
                                    </div>

                                    {/* Subtotal */}
                                    <div className="text-right flex-shrink-0">
                                      <p className="text-xs text-gray-600 dark:text-gray-400 font-bold uppercase mb-1">Subtotal</p>
                                      <p className="font-bold text-green-600 dark:text-green-400 text-lg">₦{((item.price || 0) * (item.quantity || 1)).toLocaleString()}</p>
                                    </div>
                                  </div>
                                ))}
                              </div>
                            ) : (
                              <p className="text-gray-500 dark:text-gray-400 italic">No items in this order</p>
                            )}
                          </div>

                          {/* Payment Information Section */}
                          <div className="p-6 border-b border-gray-200 dark:border-gray-700 bg-blue-50 dark:bg-blue-900">
                            <h4 className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-4">💳 Payment Breakdown</h4>
                            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
                              <div className="bg-white dark:bg-gray-800 p-4 rounded-lg border-l-4 border-green-500">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-1">Total Amount</p>
                                <p className="text-2xl font-bold text-green-600 dark:text-green-400">₦{totalAmount.toLocaleString()}</p>
                              </div>
                              <div className="bg-white dark:bg-gray-800 p-4 rounded-lg border-l-4 border-orange-500">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-1">1st Payment (50%)</p>
                                <p className="text-2xl font-bold text-orange-600 dark:text-orange-400">₦{firstPayment.toLocaleString()}</p>
                              </div>
                              <div className="bg-white dark:bg-gray-800 p-4 rounded-lg border-l-4 border-blue-500">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-1">Amount Paid</p>
                                <p className="text-2xl font-bold text-blue-600 dark:text-blue-400">₦{paidAmount.toLocaleString()}</p>
                              </div>
                              <div className="bg-white dark:bg-gray-800 p-4 rounded-lg border-l-4 border-red-500">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-1">Balance</p>
                                <p className="text-2xl font-bold text-red-600 dark:text-red-400">₦{remainingBalance.toLocaleString()}</p>
                              </div>
                              <div className="bg-white dark:bg-gray-800 p-4 rounded-lg border-l-4 border-purple-500">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-1">Monthly</p>
                                <p className="text-2xl font-bold text-purple-600 dark:text-purple-400">₦{monthlyPayment.toLocaleString()}</p>
                              </div>
                            </div>

                            {/* Payment Progress Bar */}
                            <div className="mt-4">
                              <div className="flex justify-between items-center mb-2">
                                <p className="text-sm font-bold text-gray-700 dark:text-gray-300">Payment Progress</p>
                                <p className="text-sm font-bold text-gray-700 dark:text-gray-300">{Math.round(progressPercentage)}% Completed</p>
                              </div>
                              <div className="w-full bg-gray-300 dark:bg-gray-600 rounded-full h-3 overflow-hidden">
                                <div 
                                  className="bg-gradient-to-r from-green-500 to-blue-500 h-full transition-all duration-300"
                                  style={{ width: `${Math.min(progressPercentage, 100)}%` }}
                                ></div>
                              </div>
                            </div>
                          </div>

                          {/* Shipping & Order Status */}
                          <div className="p-6 border-b border-gray-200 dark:border-gray-700">
                            <h4 className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-4">🚚 Shipping & Order Status</h4>
                            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                              <div className="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Order Status</p>
                                <span className="inline-block px-4 py-2 rounded-full text-sm font-bold bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                                  {installment.order?.orderStatus || '📋 Pending'}
                                </span>
                              </div>
                              <div className="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Shipping Address</p>
                                <p className="text-sm text-gray-900 dark:text-white font-semibold">{installment.user?.city || 'Not specified'}, {installment.user?.country || 'Nigeria'}</p>
                              </div>
                              <div className="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
                                <p className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide mb-2">Order Date</p>
                                <p className="text-sm text-gray-900 dark:text-white font-semibold">{new Date(installment.order?.createdAt || installment.createdAt).toLocaleDateString()}</p>
                              </div>
                            </div>
                          </div>

                          {/* Cheque Tracking Section */}
                          <div className="p-6 border-b border-gray-200 dark:border-gray-700 bg-amber-50 dark:bg-amber-900">
                            <div className="flex justify-between items-center mb-4">
                              <h4 className="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wide">📋 Cheque Payments ({installment.paymentPlan} Plan)</h4>
                              <button
                                onClick={() => {
                                  setManagingChequesFor(installment.id)
                                  setChequeForm({
                                    chequeId: '',
                                    issueDate: '',
                                    clearedDate: '',
                                    amount: '',
                                    bankName: '',
                                    accountNumber: '',
                                    status: 'pending',
                                    adminNotes: ''
                                  })
                                  setChequeError('')
                                }}
                                className="px-3 py-1 bg-amber-600 hover:bg-amber-700 text-white text-xs font-bold rounded-lg transition"
                              >
                                + Add Cheque
                              </button>
                            </div>
                            {installment.cheques && installment.cheques.length > 0 ? (
                              <div className="space-y-3">
                                {installment.cheques.map((cheque: any, idx: number) => (
                                  <div key={idx} className="bg-white dark:bg-gray-800 p-4 rounded-lg border-l-4 border-amber-500">
                                    <div className="flex justify-between items-start">
                                      <div className="flex-1">
                                        <p className="text-sm font-bold text-gray-900 dark:text-white">
                                          Cheque #: <span className="font-mono text-base">{cheque.chequeId || `CHQ-${idx + 1}`}</span>
                                        </p>
                                        <div className="grid grid-cols-2 md:grid-cols-4 gap-3 mt-3 text-xs">
                                          <div>
                                            <p className="text-gray-600 dark:text-gray-400 font-bold">Issue Date</p>
                                            <p className="text-gray-900 dark:text-white font-semibold">{new Date(cheque.issueDate).toLocaleDateString()}</p>
                                          </div>
                                          <div>
                                            <p className="text-gray-600 dark:text-gray-400 font-bold">Amount</p>
                                            <p className="text-green-600 dark:text-green-400 font-bold">₦{(cheque.amount || 0).toLocaleString()}</p>
                                          </div>
                                          <div>
                                            <p className="text-gray-600 dark:text-gray-400 font-bold">Bank</p>
                                            <p className="text-gray-900 dark:text-white font-semibold">{cheque.bankName || 'N/A'}</p>
                                          </div>
                                          <div>
                                            <p className="text-gray-600 dark:text-gray-400 font-bold">Account</p>
                                            <p className="text-gray-900 dark:text-white font-semibold font-mono text-xs">{cheque.accountNumber || 'N/A'}</p>
                                          </div>
                                        </div>
                                        {cheque.adminNotes && (
                                          <p className="text-xs text-gray-600 dark:text-gray-400 mt-2">
                                            <span className="font-bold">Notes:</span> {cheque.adminNotes}
                                          </p>
                                        )}
                                      </div>
                                      <div className="text-right flex-shrink-0 ml-4">
                                        <div className="mb-3">
                                          <span className={`px-3 py-1 rounded-full text-xs font-bold ${
                                            cheque.status === 'cleared' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' :
                                            cheque.status === 'pending' ? 'bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200' :
                                            cheque.status === 'bounced' ? 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200' :
                                            'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200'
                                          }`}>
                                            {cheque.status === 'cleared' && '✅'}
                                            {cheque.status === 'pending' && '⏳'}
                                            {cheque.status === 'bounced' && '❌'}
                                            {cheque.status === 'cancelled' && '🚫'}
                                            {' '}{cheque.status}
                                          </span>
                                        </div>
                                        {cheque.clearedDate && (
                                          <p className="text-xs text-gray-600 dark:text-gray-400 font-semibold">
                                            Cleared: {new Date(cheque.clearedDate).toLocaleDateString()}
                                          </p>
                                        )}
                                      </div>
                                    </div>
                                  </div>
                                ))}
                              </div>
                            ) : (
                              <p className="text-gray-600 dark:text-gray-400 italic text-sm">No cheques added yet</p>
                            )}
                          </div>

                          {/* Cheque Management Modal */}
                          {managingChequesFor === installment.id && (
                            <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
                              <div className="bg-white dark:bg-gray-800 rounded-lg shadow-2xl p-8 w-full max-w-2xl max-h-[90vh] overflow-y-auto">
                                <h3 className="text-xl font-bold text-gray-800 dark:text-white mb-6">Add Cheque Payment</h3>

                                {chequeError && (
                                  <div className="mb-4 p-4 bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-600 text-red-700 dark:text-red-200 rounded-lg">
                                    {chequeError}
                                  </div>
                                )}

                                <div className="space-y-4">
                                  {/* Cheque Number */}
                                  <div>
                                    <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">
                                      Cheque Number *
                                    </label>
                                    <input
                                      type="text"
                                      placeholder="e.g., CHQ-001 or 1234567"
                                      value={chequeForm.chequeId}
                                      onChange={(e) => setChequeForm({...chequeForm, chequeId: e.target.value})}
                                      className="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
                                    />
                                  </div>

                                  {/* Issue Date */}
                                  <div>
                                    <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">
                                      Issue Date *
                                    </label>
                                    <input
                                      type="date"
                                      value={chequeForm.issueDate}
                                      onChange={(e) => setChequeForm({...chequeForm, issueDate: e.target.value})}
                                      className="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
                                    />
                                  </div>

                                  {/* Amount */}
                                  <div>
                                    <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">
                                      Amount (₦) *
                                    </label>
                                    <input
                                      type="number"
                                      placeholder="0.00"
                                      value={chequeForm.amount}
                                      onChange={(e) => setChequeForm({...chequeForm, amount: e.target.value})}
                                      className="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
                                    />
                                  </div>

                                  {/* Bank Name */}
                                  <div>
                                    <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">
                                      Bank Name *
                                    </label>
                                    <input
                                      type="text"
                                      placeholder="e.g., First Bank, Zenith Bank"
                                      value={chequeForm.bankName}
                                      onChange={(e) => setChequeForm({...chequeForm, bankName: e.target.value})}
                                      className="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
                                    />
                                  </div>

                                  {/* Account Number */}
                                  <div>
                                    <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">
                                      Account Number
                                    </label>
                                    <input
                                      type="text"
                                      placeholder="Optional"
                                      value={chequeForm.accountNumber}
                                      onChange={(e) => setChequeForm({...chequeForm, accountNumber: e.target.value})}
                                      className="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
                                    />
                                  </div>

                                  {/* Status */}
                                  <div>
                                    <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">
                                      Status *
                                    </label>
                                    <select
                                      value={chequeForm.status}
                                      onChange={(e) => setChequeForm({...chequeForm, status: e.target.value as any})}
                                      className="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
                                    >
                                      <option value="pending">⏳ Pending</option>
                                      <option value="cleared">✅ Cleared</option>
                                      <option value="bounced">❌ Bounced</option>
                                      <option value="cancelled">🚫 Cancelled</option>
                                    </select>
                                  </div>

                                  {/* Cleared Date (conditional) */}
                                  {chequeForm.status === 'cleared' && (
                                    <div>
                                      <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">
                                        Date of Clearance *
                                      </label>
                                      <input
                                        type="date"
                                        value={chequeForm.clearedDate}
                                        onChange={(e) => setChequeForm({...chequeForm, clearedDate: e.target.value})}
                                        className="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
                                      />
                                    </div>
                                  )}

                                  {/* Admin Notes */}
                                  <div>
                                    <label className="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">
                                      Admin Notes
                                    </label>
                                    <textarea
                                      placeholder="Optional notes about this cheque..."
                                      value={chequeForm.adminNotes}
                                      onChange={(e) => setChequeForm({...chequeForm, adminNotes: e.target.value})}
                                      rows={4}
                                      className="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500"
                                    />
                                  </div>
                                </div>

                                {/* Modal Action Buttons */}
                                <div className="mt-8 flex gap-4 justify-end">
                                  <button
                                    onClick={() => setManagingChequesFor(null)}
                                    className="px-8 py-3 bg-gray-300 dark:bg-gray-600 hover:bg-gray-400 dark:hover:bg-gray-500 text-gray-800 dark:text-white font-bold rounded-lg transition"
                                  >
                                    Cancel
                                  </button>
                                  <button
                                    onClick={async () => {
                                      // Validate required fields
                                      if (!chequeForm.chequeId.trim() || !chequeForm.issueDate || !chequeForm.amount || !chequeForm.bankName.trim()) {
                                        setChequeError('Please fill in all required fields (Cheque Number, Issue Date, Amount, Bank Name)');
                                        return;
                                      }

                                      if (chequeForm.status === 'cleared' && !chequeForm.clearedDate) {
                                        setChequeError('Please provide date of clearance for cleared cheques');
                                        return;
                                      }

                                      setSavingCheque(true);
                                      setChequeError('');

                                      try {
                                        const response = await apiClient.post(`/installments/${installment.id}/cheque`, {
                                          chequeId: chequeForm.chequeId,
                                          issueDate: chequeForm.issueDate,
                                          clearedDate: chequeForm.clearedDate,
                                          amount: parseFloat(chequeForm.amount),
                                          bankName: chequeForm.bankName,
                                          accountNumber: chequeForm.accountNumber,
                                          status: chequeForm.status,
                                          adminNotes: chequeForm.adminNotes
                                        });

                                        // Success - close modal and refresh data
                                        setManagingChequesFor(null);
                                        setChequeForm({
                                          chequeId: '',
                                          issueDate: '',
                                          clearedDate: '',
                                          amount: '',
                                          bankName: '',
                                          accountNumber: '',
                                          status: 'pending',
                                          adminNotes: ''
                                        });
                                        
                                        // Refresh installments data
                                        await fetchDashboardData();
                                      } catch (error: any) {
                                        setChequeError(error.response?.data?.message || 'Failed to save cheque');
                                      } finally {
                                        setSavingCheque(false);
                                      }
                                    }}
                                    disabled={savingCheque}
                                    className="px-8 py-3 bg-amber-600 hover:bg-amber-700 disabled:bg-amber-400 text-white font-bold rounded-lg transition"
                                  >
                                    {savingCheque ? 'Saving...' : '💾 Save Cheque'}
                                  </button>
                                </div>
                              </div>
                            </div>
                          )}

                          {/* Action Buttons */}
                          <div className="p-6 bg-gray-50 dark:bg-gray-700 flex gap-3 justify-end">
                            <button 
                              onClick={async () => {
                                try {
                                  // Update order payment status
                                  await apiClient.patch(`/orders/${installment.orderId}/payment-status`, {
                                    paymentStatus: 'paid'
                                  });
                                  
                                  // Refresh data
                                  await fetchDashboardData();
                                } catch (error: any) {
                                  alert(error.response?.data?.message || 'Failed to approve payment');
                                }
                              }}
                              className="px-6 py-3 bg-green-600 hover:bg-green-700 active:bg-green-800 text-white font-bold rounded-lg transition text-sm shadow-md hover:shadow-lg"
                            >
                              ✅ Approve Payment
                            </button>
                            <button 
                              onClick={async () => {
                                try {
                                  // Update order status to shipped
                                  await apiClient.patch(`/orders/${installment.orderId}/status`, {
                                    status: 'shipped'
                                  });
                                  
                                  // Refresh data
                                  await fetchDashboardData();
                                } catch (error: any) {
                                  alert(error.response?.data?.message || 'Failed to mark as shipped');
                                }
                              }}
                              className="px-6 py-3 bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-bold rounded-lg transition text-sm shadow-md hover:shadow-lg"
                            >
                              📦 Mark Shipped
                            </button>
                            <button 
                              onClick={async () => {
                                try {
                                  // Update order status to delivered
                                  await apiClient.patch(`/orders/${installment.orderId}/status`, {
                                    status: 'delivered'
                                  });
                                  
                                  // Refresh data
                                  await fetchDashboardData();
                                } catch (error: any) {
                                  alert(error.response?.data?.message || 'Failed to mark as delivered');
                                }
                              }}
                              className="px-6 py-3 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white font-bold rounded-lg transition text-sm shadow-md hover:shadow-lg"
                            >
                              ✔️ Mark Delivered
                            </button>
                            <button 
                              onClick={async () => {
                                if (confirm('Are you sure you want to cancel this order?')) {
                                  try {
                                    // Cancel the installment
                                    await apiClient.post(`/installments/${installment.id}/cancel`, {});
                                    
                                    // Also cancel the order
                                    await apiClient.patch(`/orders/${installment.orderId}/status`, {
                                      status: 'cancelled'
                                    });
                                    
                                    // Refresh data
                                    await fetchDashboardData();
                                  } catch (error: any) {
                                    alert(error.response?.data?.message || 'Failed to cancel order');
                                  }
                                }
                              }}
                              className="px-6 py-3 bg-red-600 hover:bg-red-700 active:bg-red-800 text-white font-bold rounded-lg transition text-sm shadow-md hover:shadow-lg"
                            >
                              🚫 Cancel Order
                            </button>
                          </div>
                        </div>
                      )
                    })}
                  </div>
                )}
              </div>
            )}
          </div>
        </div>
      </div>
    </>
  )
}
