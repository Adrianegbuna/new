              <div 
                className="bg-gradient-to-br from-pink-500 to-rose-600 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => setActiveTab('cheques')}
              >
                <div>
