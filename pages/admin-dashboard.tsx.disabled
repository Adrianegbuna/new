import Head from 'next/head'
import { useState, useEffect, useRef } from 'react'
import Header from '../components/Header'
import Link from 'next/link'
import { useRouter } from 'next/router'
import { useCurrency } from '../context/CurrencyContext'
import { apiClient } from '../lib/api-client'
import { useAuthStore } from '@/store/authStore'
import { S3ImageUploader } from '../components/S3ImageUploader'

interface User {
  id: string
  firstName: string
  lastName: string
  email: string
  phone: string
  country: string
  city: string
  role: string
  accountType: string
  createdAt: string
}

interface Customer {
  id: string
  fullName: string
  email: string
  phone: string
  address: string
  city: string
  state: string
  postalCode: string
}

interface Order {
  id: string
  orderNumber: string
  userId?: string
  customerName?: string
  total?: number
  totalPrice?: number
  orderStatus: string
  paymentStatus: string
  createdAt: string
  updatedAt?: string
  items: OrderItem[]
  customer?: Customer
  store?: Store
  shippingAddress?: string
  trackingNumber?: string
  estimatedDelivery?: string
}

interface OrderItem {
  id: string
  productId?: string | number
  name?: string
  price: number
  quantity: number
  image?: string
  storeName?: string
  storeCity?: string
  // ✅ FIX: Add product object for nested API response
  product?: {
    id: string
    name: string
    price: number
    quantity: number
    image?: string
    sku?: string
    productCode?: string
    category?: string
    store?: {
      id: string
      name: string
      city: string
    }
  }
}

interface Product {
  id: number
  name: string
  price: number
  category: number
  stock: number
  storeId: number
  country: string
  image?: string
  store?: Store
}

interface Store {
  id: number | string
  name: string
  ownerId?: string
  country?: string
  city: string
  slug?: string
  logo?: string
  logoUrl?: string
  logoKey?: string
  email?: string
  phone?: string
  location?: string
}

interface SubCategory {
  id: string
  categoryId: string
  name: string
  description?: string
  icon?: string
  image?: string
}

interface Category {
  id: string
  name: string
  description?: string
  icon?: string
  image?: string
  subcategories?: SubCategory[]
}

interface Stats {
  totalUsers: number
  totalVendors: number
  totalInstallers: number
  totalCustomers: number
  totalOrders: number
  totalRevenue: number
  totalProducts: number
  totalStores: number
  pendingProducts: number
}

export default function AdminDashboard() {
  const router = useRouter()
  const { formatPrice } = useCurrency()
  const { user, token, isHydrated } = useAuthStore()
  
  const [activeTab, setActiveTab] = useState<'overview' | 'users' | 'orders' | 'products' | 'stores' | 'quotations' | 'packages' | 'jobs' | 'service-requests' | 'analytics' | 'inventory' | 'promotions' | 'reviews' | 'payments' | 'cheques' | 'categories' | 'post-product' | 'flash-deals' | 'swap-resell' | 'installments'>('overview')
  const [users, setUsers] = useState<User[]>([])
  const [orders, setOrders] = useState<Order[]>([])
  const [products, setProducts] = useState<Product[]>([])
  const [stores, setStores] = useState<Store[]>([])
  const [categories, setCategories] = useState<Category[]>([])
  const [loading, setLoading] = useState(true)
  const [expandedOrder, setExpandedOrder] = useState<string | null>(null)
  const [expandedCategory, setExpandedCategory] = useState<string | null>(null)
  
  // Order status tracking
  const [orderStatusChanges, setOrderStatusChanges] = useState<{ [orderId: string]: { deliveryStatus: string; paymentStatus: string } }>({})
  const [refundConfirmOrderId, setRefundConfirmOrderId] = useState<string | null>(null)
  const [refundedOrders, setRefundedOrders] = useState<Set<string>>(new Set())
  const [updatingOrderId, setUpdatingOrderId] = useState<string | null>(null)
  const [newOrderStatus, setNewOrderStatus] = useState('')
  const [updateStatusError, setUpdateStatusError] = useState('')
  const [updateStatusLoading, setUpdateStatusLoading] = useState(false)
  
  // Service Requests state
  const [serviceRequests, setServiceRequests] = useState<any[]>([])
  const [serviceRequestsLoading, setServiceRequestsLoading] = useState(false)
  
  // Installments state
  const [installments, setInstallments] = useState<any[]>([])
  const [installmentsLoading, setInstallmentsLoading] = useState(false)
  
  // Payout Requests state
  const [payoutRequests, setPayoutRequests] = useState<any[]>([])
  const [processingPayoutId, setProcessingPayoutId] = useState<string | null>(null)
  const [payoutNotes, setPayoutNotes] = useState('')
  
  // Cheque management state
  const [managingChequesFor, setManagingChequesFor] = useState<string | null>(null)
  const [chequeForm, setChequeForm] = useState({
    chequeId: '',
    issueDate: '',
    clearedDate: '',
    amount: '',
    bankName: '',
    accountNumber: '',
    status: 'pending' as 'pending' | 'cleared' | 'bounced' | 'cancelled',
    adminNotes: ''
  })
  const [savingCheque, setSavingCheque] = useState(false)
  const [chequeError, setChequeError] = useState('')
  
  // Category form states
  const [categoryForm, setCategoryForm] = useState({ name: '', description: '', icon: '', image: '' })
  const [subcategoryForm, setSubcategoryForm] = useState({ name: '', description: '', icon: '', image: '' })
  const [editingCategory, setEditingCategory] = useState<string | null>(null)
  const [editingSubcategory, setEditingSubcategory] = useState<string | null>(null)
  const [selectedCategoryForSubcategory, setSelectedCategoryForSubcategory] = useState<string | null>(null)

  // Post Product to Vendor Store form states
  const [vendorStores, setVendorStores] = useState<Store[]>([])
  const [postProductForm, setPostProductForm] = useState({
    name: '',
    description: '',
    price: '',
    image: '',
    category: '',
    subcategory: '',
    stock: '',
    storeId: ''
  })
  const [postingProduct, setPostingProduct] = useState(false)

  // Flash Deals form states
  const [flashDealForm, setFlashDealForm] = useState({
    selectedPackageName: '',
    batteryType: 'lithium',
    inverterType: 'standard',
    powers: '3 bedrooms, lights, fan, TV, decoder, phone charging',
    warranty: 'Panels (10–25 yrs) • Inverter (1–2 yrs) • Battery — Lithium (3–5 yrs) / Tubular (1–2 yrs) • Installation kit (1 yr)',
    price: '',
    storeId: '',
    images: [] as string[]
  })
  const [postingFlashDeal, setPostingFlashDeal] = useState(false)

  // Flash Deals management states
  const [flashDeals, setFlashDeals] = useState<any[]>([])
  const [editingFlashDealId, setEditingFlashDealId] = useState<string | null>(null)
  const [editFlashDealForm, setEditFlashDealForm] = useState<any>(null)
  const [savingFlashDeal, setSavingFlashDeal] = useState(false)
  
  const [stats, setStats] = useState<Stats>({
    totalUsers: 0,
    totalVendors: 0,
    totalInstallers: 0,
    totalCustomers: 0,
    totalOrders: 0,
    totalRevenue: 0,
    totalProducts: 0,
    totalStores: 0,
    pendingProducts: 0
  })

  const hasFetched = useRef(false)
  const intervalRef = useRef<NodeJS.Timeout | null>(null)

  useEffect(() => {
    if (!isHydrated) return

    if (!user || !token) {
      router.push('/login')
      return
    }
    
    if (user.role !== 'admin') {
      router.push('/')
      return
    }

    // Only fetch once on mount
    if (!hasFetched.current) {
      hasFetched.current = true
      setLoading(true)
      fetchDashboardData()
    }

    // Setup auto-refresh every 10 seconds
    if (!intervalRef.current) {
      intervalRef.current = setInterval(() => {
        if (typeof window !== 'undefined' && document.visibilityState === 'visible') {
          fetchDashboardData()
        }
      }, 10000)
    }

    return () => {
      if (intervalRef.current) {
        clearInterval(intervalRef.current)
        intervalRef.current = null
      }
    }
  }, [isHydrated, user, token, router])

  const fetchDashboardData = async () => {
    try {
      const [usersRes, ordersRes, productsRes, storesRes, categoriesRes, flashDealsRes, serviceReqRes, installmentsRes, payoutRes] = await Promise.all([
        apiClient.get('/admin/users'),
        apiClient.get('/orders/all'),
        apiClient.get('/admin/products'),
        apiClient.get('/admin/stores'),
        apiClient.get('/admin/categories'),
        apiClient.get('/packages?featured=true'),
        apiClient.get('/service-requests/admin/all').catch(() => ({ data: [] })),
        apiClient.get('/installments/admin/all-installments').catch(() => ({ data: [] })),
        apiClient.get('/referrals/admin/payouts?status=pending&limit=100').catch(() => ({ data: [] }))
      ])

      if (usersRes.data) {
        const usersData = usersRes.data
        setUsers(usersData)
        const vendors = usersData.filter((u: User) => u.role === 'vendor' || u.accountType === 'vendor')
        const installers = usersData.filter((u: User) => u.role === 'installer' || u.accountType === 'installer')
        const customers = usersData.filter((u: User) => u.role === 'customer' || u.accountType === 'customer')
        
        setStats(prev => ({...prev, totalUsers: usersData.length, totalVendors: vendors.length, totalInstallers: installers.length, totalCustomers: customers.length}))
      }

      if (ordersRes.data) {
        // Get orders from backend - real database data only
        let ordersData = ordersRes.data?.data || ordersRes.data || []
        
        // Ensure it's an array and not empty
        if (!Array.isArray(ordersData)) {
          ordersData = []
        }
        
        // Sort by newest first
        ordersData = ordersData.sort((a: Order, b: Order) => 
          new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
        )
        
        setOrders(ordersData)
        const totalRevenue = ordersData.reduce((sum: number, order: Order) => sum + Number(order.totalPrice || order.total), 0)
        setStats(prev => ({...prev, totalOrders: ordersData.length, totalRevenue}))
      }

      if (productsRes.data) {
        setProducts(productsRes.data)
        setStats(prev => ({...prev, totalProducts: productsRes.data.length}))
      }

      if (storesRes.data) {
        setStores(storesRes.data)
        setStats(prev => ({...prev, totalStores: storesRes.data.length}))
      }

      if (categoriesRes.data) {
        setCategories(categoriesRes.data)
      }

      if (flashDealsRes.data) {
        const dealsData = Array.isArray(flashDealsRes.data) ? flashDealsRes.data : (flashDealsRes.data?.data || [])
        setFlashDeals(dealsData)
      }

      if (serviceReqRes.data) {
        const reqData = Array.isArray(serviceReqRes.data) ? serviceReqRes.data : (serviceReqRes.data?.data || [])
        setServiceRequests(reqData)
      }

      if (installmentsRes.data) {
        const instData = Array.isArray(installmentsRes.data) ? installmentsRes.data : (installmentsRes.data?.data || [])
        setInstallments(instData)
      }

      if (payoutRes.data) {
        const payoutData = Array.isArray(payoutRes.data) ? payoutRes.data : (payoutRes.data?.data || [])
        setPayoutRequests(payoutData)
      }

      setLoading(false)
    } catch (error) {
      setLoading(false)
    }
  }

  const deleteUser = async (userId: string) => {
    if (!confirm('Are you sure you want to delete this user?')) return
    
    try {
      await apiClient.delete(`/admin/users/${userId}`)
      setUsers(users.filter(u => u.id !== userId))
      alert('User deleted successfully')
    } catch (error) {
      alert('Error deleting user')
    }
  }

  // Category CRUD Functions
  const handleCreateCategory = async () => {
    if (!categoryForm.name.trim()) {
      alert('Category name is required')
      return
    }

    try {
      const res = await apiClient.post('/admin/categories', categoryForm)
      setCategories([...categories, res.data])
      setCategoryForm({ name: '', description: '', icon: '', image: '' })
      alert('Category created successfully')
    } catch (error: any) {
      alert(error.response?.data?.message || 'Error creating category')
    }
  }

  const handleUpdateCategory = async (categoryId: string) => {
    if (!categoryForm.name.trim()) {
      alert('Category name is required')
      return
    }

    try {
      const res = await apiClient.patch(`/admin/categories/${categoryId}`, categoryForm)
      setCategories(categories.map(c => c.id === categoryId ? res.data : c))
      setEditingCategory(null)
      setCategoryForm({ name: '', description: '', icon: '', image: '' })
      alert('Category updated successfully')
    } catch (error: any) {
      alert(error.response?.data?.message || 'Error updating category')
    }
  }

  const handleDeleteCategory = async (categoryId: string) => {
    if (!confirm('Are you sure you want to delete this category and all its subcategories?')) return

    try {
      await apiClient.delete(`/admin/categories/${categoryId}`)
      setCategories(categories.filter(c => c.id !== categoryId))
      alert('Category deleted successfully')
    } catch (error: any) {
      alert(error.response?.data?.message || 'Error deleting category')
    }
  }

  const handleCreateSubcategory = async (categoryId: string) => {
    if (!subcategoryForm.name.trim()) {
      alert('Subcategory name is required')
      return
    }

    try {
      const res = await apiClient.post(`/admin/categories/${categoryId}/subcategories`, subcategoryForm)
      setCategories(categories.map(c => c.id === categoryId ? { ...c, subcategories: [...(c.subcategories || []), res.data] } : c))
      setSubcategoryForm({ name: '', description: '', icon: '', image: '' })
      setSelectedCategoryForSubcategory(null)
      alert('Subcategory created successfully')
    } catch (error: any) {
      alert(error.response?.data?.message || 'Error creating subcategory')
    }
  }

  const handleUpdateSubcategory = async (categoryId: string, subcategoryId: string) => {
    if (!subcategoryForm.name.trim()) {
      alert('Subcategory name is required')
      return
    }

    try {
      const res = await apiClient.patch(`/admin/categories/${categoryId}/subcategories/${subcategoryId}`, subcategoryForm)
      setCategories(categories.map(c => c.id === categoryId ? {
        ...c,
        subcategories: (c.subcategories || []).map(sc => sc.id === subcategoryId ? res.data : sc)
      } : c))
      setEditingSubcategory(null)
      setSubcategoryForm({ name: '', description: '', icon: '', image: '' })
      alert('Subcategory updated successfully')
    } catch (error: any) {
      alert(error.response?.data?.message || 'Error updating subcategory')
    }
  }

  const handleDeleteSubcategory = async (categoryId: string, subcategoryId: string) => {
    if (!confirm('Are you sure you want to delete this subcategory?')) return

    try {
      await apiClient.delete(`/admin/categories/${categoryId}/subcategories/${subcategoryId}`)
      setCategories(categories.map(c => c.id === categoryId ? {
        ...c,
        subcategories: (c.subcategories || []).filter(sc => sc.id !== subcategoryId)
      } : c))
      alert('Subcategory deleted successfully')
    } catch (error: any) {
      alert(error.response?.data?.message || 'Error deleting subcategory')
    }
  }

  // Fetch vendor stores for admin posting
  useEffect(() => {
    if (activeTab === 'post-product' || activeTab === 'flash-deals') {
      fetchVendorStores()
    }
  }, [activeTab])

  const fetchVendorStores = async () => {
    try {
      const res = await apiClient.get('/admin/stores/verified')
      setVendorStores(res.data)
    } catch (error: any) {
      alert('Failed to load vendor stores')
    }
  }

  // Handle posting product to vendor store
  const handlePostProduct = async () => {
    if (!postProductForm.name.trim() || !postProductForm.description.trim() || !postProductForm.price || !postProductForm.image || !postProductForm.category || !postProductForm.stock || !postProductForm.storeId) {
      alert('Please fill in all required fields')
      return
    }

    setPostingProduct(true)
    try {
      await apiClient.post('/admin/products/create', {
        name: postProductForm.name,
        description: postProductForm.description,
        price: parseFloat(postProductForm.price),
        image: postProductForm.image,
        category: postProductForm.category,
        subcategory: postProductForm.subcategory || null,
        stock: parseInt(postProductForm.stock),
        storeId: postProductForm.storeId
      })
      alert('✓ Product posted to vendor store successfully!')
      setPostProductForm({
        name: '',
        description: '',
        price: '',
        image: '',
        category: '',
        subcategory: '',
        stock: '',
        storeId: ''
      })
    } catch (error: any) {
      alert(error.response?.data?.message || 'Failed to post product')
    } finally {
      setPostingProduct(false)
    }
  }

  // Handle posting flash deal (solar package)
  const handlePostFlashDeal = async () => {
    if (!flashDealForm.selectedPackageName || !flashDealForm.price || !flashDealForm.storeId) {
      alert('Please fill in package type, price, and select a store')
      return
    }

    setPostingFlashDeal(true)
    try {
      const response = await apiClient.post('/packages/admin/flash-deals', {
        selectedPackageName: flashDealForm.selectedPackageName,
        batteryType: flashDealForm.batteryType,
        maxBatteryLithium: flashDealForm.batteryType === 'lithium' ? 10 : 0,
        maxBatteryTubular: flashDealForm.batteryType === 'tubular' ? 10 : 0,
        inverterType: flashDealForm.inverterType,
        powers: flashDealForm.powers,
        warranty: flashDealForm.warranty,
        price: parseFloat(flashDealForm.price),
        storeId: flashDealForm.storeId,
        images: flashDealForm.images
      })

      alert('✓ Solar package posted as flash deal successfully!')
      setFlashDealForm({
        selectedPackageName: '',
        batteryType: 'lithium',
        inverterType: 'standard',
        powers: '3 bedrooms, lights, fan, TV, decoder, phone charging',
        warranty: 'Panels (10–25 yrs) • Inverter (1–2 yrs) • Battery — Lithium (3–5 yrs) / Tubular (1–2 yrs) • Installation kit (1 yr)',
        price: '',
        storeId: '',
        images: []
      })
    } catch (error: any) {
      alert(error.response?.data?.message || 'Failed to post flash deal')
    } finally {
      setPostingFlashDeal(false)
    }
  }

  const handleEditFlashDeal = async (deal: any) => {
    setEditingFlashDealId(deal.id)
    const basePrice = deal.vendorPrice / 1.10
    setEditFlashDealForm({
      id: deal.id,
      selectedPackageName: deal.name,
      batteryType: deal.category || 'lithium',
      inverterType: deal.inverterType,
      powers: deal.powers,
      warranty: deal.warranty,
      price: basePrice.toString(),
      storeId: deal.storeId,
      images: deal.images || []
    })
  }

  const handleSaveFlashDeal = async () => {
    if (!editFlashDealForm.selectedPackageName || !editFlashDealForm.price || !editFlashDealForm.storeId) {
      alert('Please fill in all required fields')
      return
    }

    setSavingFlashDeal(true)
    try {
      await apiClient.put(`/packages/admin/flash-deals/${editFlashDealForm.id}`, {
        selectedPackageName: editFlashDealForm.selectedPackageName,
        batteryType: editFlashDealForm.batteryType,
        maxBatteryLithium: editFlashDealForm.batteryType === 'lithium' ? 10 : 0,
        maxBatteryTubular: editFlashDealForm.batteryType === 'tubular' ? 10 : 0,
        inverterType: editFlashDealForm.inverterType,
        powers: editFlashDealForm.powers,
        warranty: editFlashDealForm.warranty,
        price: parseFloat(editFlashDealForm.price),
        storeId: editFlashDealForm.storeId,
        images: editFlashDealForm.images
      })

      alert('✓ Flash deal updated successfully!')
      setEditingFlashDealId(null)
      setEditFlashDealForm(null)
      fetchDashboardData()
    } catch (error: any) {
      alert(error.response?.data?.message || 'Failed to save flash deal')
    } finally {
      setSavingFlashDeal(false)
    }
  }

  const handleDeleteFlashDeal = async (dealId: string) => {
    if (!confirm('Are you sure you want to delete this flash deal?')) return

    try {
      await apiClient.delete(`/packages/admin/flash-deals/${dealId}`)
      alert('✓ Flash deal deleted successfully!')
      fetchDashboardData()
    } catch (error: any) {
      alert(error.response?.data?.message || 'Failed to delete flash deal')
    }
  }

  if (loading) {
    return (
      <>
        <Head><title>Admin Dashboard - RenewableZmart</title></Head>
        <div className="min-h-screen bg-gray-100 flex items-center justify-center">
          <div className="text-center">
            <div className="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-teal-600"></div>
            <p className="text-gray-600 font-semibold mt-4">Loading dashboard...</p>
          </div>
        </div>
      </>
    )
  }

  return (
    <>
      <Head><title>Admin Dashboard - RenewableZmart</title></Head>
      <div className="min-h-screen bg-gradient-to-b from-gray-50 to-gray-100">
        <Header />
        
        <div className="bg-gradient-to-r from-teal-600 to-emerald-600 text-white py-8">
          <div className="container mx-auto px-4">
            <div className="flex justify-between items-center">
              <div>
                <h1 className="text-4xl font-bold mb-2">Admin Dashboard</h1>
                <p className="font-semibold">Platform Overview & Management Center</p>
              </div>
              <Link href="/admin-profile" className="bg-white text-teal-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">
                ⚙️ Admin Profile
              </Link>
            </div>
          </div>
        </div>

        <div className="container mx-auto px-4 py-10">
          <div className="mb-12">
            <h2 className="text-2xl font-bold text-gray-900 mb-6">Key Metrics</h2>
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
              <div className="bg-white rounded-xl shadow-md p-6 border-l-4 border-teal-500">
                <p className="text-sm text-gray-600 font-bold mb-2">Total Users</p>
                <p className="text-4xl font-bold text-teal-600">{stats.totalUsers}</p>
              </div>
              <div className="bg-white rounded-xl shadow-md p-6 border-l-4 border-blue-500">
                <p className="text-sm text-gray-600 font-bold mb-2">Total Orders</p>
                <p className="text-4xl font-bold text-blue-600">{stats.totalOrders}</p>
              </div>
              <div className="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500">
                <p className="text-sm text-gray-600 font-bold mb-2">Total Revenue</p>
                <p className="text-4xl font-bold text-green-600">{formatPrice(stats.totalRevenue)}</p>
              </div>
              <div className="bg-white rounded-xl shadow-md p-6 border-l-4 border-purple-500">
                <p className="text-sm text-gray-600 font-bold mb-2">Products & Stores</p>
                <p className="text-4xl font-bold text-purple-600">{stats.totalProducts}</p>
              </div>
            </div>
          </div>

          <div className="mb-12">
            <h2 className="text-2xl font-bold text-gray-900 mb-6">Quick Actions</h2>
            <div className="grid grid-cols-2 md:grid-cols-5 lg:grid-cols-10 gap-4">
              {/* Post Product */}
              <div 
                className="bg-gradient-to-br from-teal-500 to-emerald-600 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => setActiveTab('post-product')}
              >
                <div>
                  <div className="text-3xl mb-2">📦</div>
                  <h3 className="text-base font-bold mb-1">Post Product</h3>
                </div>
                <p className="text-xs opacity-90">Add to authorized dealer stores</p>
              </div>

              {/* Verify Vendors */}
              <div 
                className="bg-gradient-to-br from-purple-500 to-purple-700 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => router.push('/admin-vendor-verification')}
              >
                <div>
                  <div className="text-3xl mb-2">✓</div>
                  <h3 className="text-base font-bold mb-1">Verify Vendors</h3>
                </div>
                <p className="text-xs opacity-90">Approve registrations</p>
              </div>

              {/* Verify Installers */}
              <div 
                className="bg-gradient-to-br from-cyan-500 to-teal-600 text-white rounded-xl shadow-lg p-4 hover:shadow-xl transition cursor-pointer h-full flex flex-col justify-between min-h-[160px]"
                onClick={() => router.push('/admin-installer-verification')}
              >
                <div>
